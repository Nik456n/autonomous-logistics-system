                    if (intersectsWarehouse(currentWarehousePoints, true)) {
                        alert('Склад не может пересекаться с перегородками!');
                        return;
                    }
                }
            }
            
            if (pointsInWarehouse.length > 0) {
                alert(`Нельзя создать склад, который содержит:\n${pointsInWarehouse.join('\n')}`);
                return;
