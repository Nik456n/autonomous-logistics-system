            }
            
            // Проверяем, не пересекается ли склад с препятствиями
            for (let obstacle of obstacles) {
                if (obstacle.withArea) {
                    // Проверяем каждую точку склада на пересечение с препятствиями
                    for (let point of warehouseCoords) {
                        if (isPointInPolygon(point[0], point[1], obstacle.coordinates)) {
