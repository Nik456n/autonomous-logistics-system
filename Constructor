        // Рисуем стрелочки в тоннеле
        function drawTunnelArrows(tunnel, scale) {
            ctx.strokeStyle = '#ffffff';
            ctx.lineWidth = 1;
            ctx.fillStyle = '#ffffff';
            
            // Рисуем стрелочки вдоль тоннеля
            for (let i = 0; i < tunnel.points.length - 1; i++) {
                const start = tunnel.points[i];
                const end = tunnel.points[i + 1];
                
                const dx = end.x - start.x;
                const dy = end.y - start.y;
                const length = Math.sqrt(dx * dx + dy * dy);
                const unitDx = dx / length;
                const unitDy = dy / length;
                
                // Рисуем несколько стрелочек на каждом сегменте
                const arrowCount = Math.floor(length / 5);
                for (let j = 0; j < arrowCount; j++) {
                    const t = (j + tunnelAnimationOffset) / arrowCount;
                    const arrowX = start.x + dx * t;
                    const arrowY = start.y + dy * t;
                    
                    drawArrow(
                        offsetX + arrowX * scale,
                        offsetY + (roomWidth - arrowY) * scale,
                        unitDx, unitDy,
                        6 * scale / 2.5 // Уменьшена длина стрелки в 2.5 раза
                    );
                }
            }
        }

        // Рисуем стрелку (УМЕНЬШЕННЫЙ РАЗМЕР - еще в 3 раза)
        function drawArrow(x, y, dx, dy, length) {
            const headLength = length * 0.133; // Уменьшено еще в 3 раза (0.4/3)
            const headWidth = length * 0.1;    // Уменьшено еще в 3 раза (0.3/3)
            
            // Линия стрелки - уменьшена длина
            const arrowLength = length * 0.6; // Уменьшаем длину стрелки, чтобы она не выходит за границы тоннеля
            ctx.beginPath();
            ctx.moveTo(x, y);
            ctx.lineTo(x + dx * arrowLength, y - dy * arrowLength);
            ctx.stroke();
            
            // Голова стрелки (уменьшенный треугольник)
            ctx.beginPath();
            ctx.moveTo(x + dx * arrowLength, y - dy * arrowLength);
            ctx.lineTo(
                x + dx * (arrowLength - headLength) - dy * headWidth,
                y - dy * (arrowLength - headLength) - dx * headWidth
            );
            ctx.lineTo(
                x + dx * (arrowLength - headLength) + dy * headWidth,
                y - dy * (arrowLength - headLength) + dx * headWidth
            );
            ctx.closePath();
            ctx.fill();
        }

