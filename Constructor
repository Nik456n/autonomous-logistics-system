        // Отрисовка сетки
        function drawGrid() {
            const scale = baseScale * userZoom;
            
            // Автоматически подбираем размер сетки в зависимости от масштаба
            let dynamicGridSize = gridSize;
            if (roomLength > 100 || roomWidth > 100) {
                dynamicGridSize = 10;
            }
            if (roomLength > 200 || roomWidth > 200) {
                dynamicGridSize = 20;
            }
            if (roomLength > 500 || roomWidth > 500) {
                dynamicGridSize = 50;
            }
            
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
            ctx.lineWidth = 1;
            
            // Вертикальные линии
            for (let x = 0; x <= roomLength; x += dynamicGridSize) {
                ctx.beginPath();
                ctx.moveTo(offsetX + x * scale, offsetY);
                ctx.lineTo(offsetX + x * scale, offsetY + roomWidth * scale);
                ctx.stroke();
                
                // Подписи координат (только если масштаб достаточный)
                if (userZoom > 0.5) {
                    ctx.fillStyle = 'rgba(255, 255, 255, 0.5)';
                    ctx.font = '10px Arial';
                    ctx.textAlign = 'center';
                    ctx.fillText(x, offsetX + x * scale, offsetY + roomWidth * scale + 15);
                }
            }
            
            // Горизонтальные линии
            for (let y = 0; y <= roomWidth; y += dynamicGridSize) {
                ctx.beginPath();
                ctx.moveTo(offsetX, offsetY + y * scale);
                ctx.lineTo(offsetX + roomLength * scale, offsetY + y * scale);
                ctx.stroke();
                
                // Подписи координат (только если масштаб достаточный)
                if (userZoom > 0.5) {
                    ctx.fillStyle = 'rgba(255, 255, 255, 0.5)';
                    ctx.font = '10px Arial';
                    ctx.textAlign = 'right';
                    ctx.fillText(y, offsetX - 5, offsetY + (roomWidth - y) * scale);
                }
            }
        }

        // Обновление карты цеха
        function updateFactoryMap() {
            // Получаем актуальные размеры цеха
            roomLength = parseFloat(document.getElementById('length').value) || 50;
            roomWidth = parseFloat(document.getElementById('width').value) || 30;
            
            // Очищаем canvas
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Рассчитываем базовый масштаб
            baseScale = Math.min(
                (canvas.width - 40) / roomLength,
                (canvas.height - 40) / roomWidth
            );
            
            const scale = baseScale * userZoom;
            
            // Если offsetX и offsetY не установлены, центрируем карту
            if (offsetX === 0 && offsetY === 0) {
                offsetX = (canvas.width - roomLength * scale) / 2;
                offsetY = (canvas.height - roomWidth * scale) / 2;
            }
            
