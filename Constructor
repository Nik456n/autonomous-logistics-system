                    }
                    // Проверяем каждую точку препятствия на пересечение со складом
                    for (let point of obstacle.coordinates) {
                        if (isPointInPolygon(point[0], point[1], warehouseCoords)) {
                            alert('Склад не может пересекаться с препятствиями!');
                            return;
