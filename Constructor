        // Функция отправки данных на сервер для оптимизации логистики с помощью ИИ
        async function sendToGigaChat() {
            // Проверка пустых полей
            if (!checkEmptyFields()) {
                alert('❌ Укажите недостающие данные во всех точках погрузки, выгрузки и зарядки');
                return;
            }
            
            // Проверка соответствия типов грузов
            const cargoCheck = checkCargoTypes();
            if (!cargoCheck.valid) {
                alert(`❌ Ошибка, груз "${cargoCheck.missingCargo}" не поставляется`);
                return;
            }
            
            // Проверка существования кнопки
            const submitBtn = document.querySelector('.btn-primary');
            if (!submitBtn) {
                alert('❌ Ошибка: кнопка отправки не найдена');
                return;
            }
            
            // Сбор данных о помещении
            const roomData = {
                length: parseFloat(document.getElementById('length').value) || 50,
                width: parseFloat(document.getElementById('width').value) || 30,
                height: parseFloat(document.getElementById('height').value) || 10
            };

            // Сбор дополнительных деталей
            const additionalDetails = document.getElementById('additionalDetails').value;

            // Формируем полный объект данных
            const factoryData = {
                room: roomData,
                warehouse: warehouseArea,
                basePoint: basePoint,
                obstacles: obstacles,
                loadingPoints: loadingPoints,
                unloadingPoints: unloadingPoints,
                chargingPoints: chargingPoints,
                tunnels: tunnels,
                robotTypes: robotTypes,
                additionalDetails: additionalDetails
            };

            console.log('Данные для отправки:', factoryData);
            
            try {
                // Показываем индикатор загрузки
                const originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = '⏳ Отправка на сервер...';
                submitBtn.disabled = true;

                // Отправка данных на сервер
                const response = await fetch('http://127.0.0.1:8030/optimize-logistics', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(factoryData)
                });

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const result = await response.json();
                
                if (result.success) {
                    alert('✅ Логика движения роботов успешно сгенерирована!\n\nОткрываю страницу с результатом...');
                    
                    // Сохраняем результат в localStorage для передачи на страницу результатов
                    localStorage.setItem('gigaChatResponse', JSON.stringify({
                        success: true,
                        controllerCode: result.controllerCode,
                        fullResponse: result.fullResponse,
                        requestData: factoryData, // Сохраняем и исходные данные для контекста
                        timestamp: new Date().toISOString()
                    }));
                    
                    // Открываем страницу с результатами
                    window.open('giga_response.html', '_blank');
                    
                } else {
                    throw new Error(result.error || 'Неизвестная ошибка сервера');
                }
                
            } catch (error) {
                console.error('Ошибка при отправке данных:', error);
                alert('❌ Ошибка при отправке данных на сервер:\n' + error.message);
                
                // Сохраняем ошибку для показа на странице результатов
                localStorage.setItem('gigaChatResponse', JSON.stringify({
                    success: false,
                    error: error.message,
                    timestamp: new Date().toISOString()
                }));
                
                // Все равно открываем страницу с результатами (чтобы показать ошибку)
                window.open('giga_response.html', '_blank');
            } finally {
                // Восстанавливаем кнопку
                const submitBtn = document.querySelector('.btn-primary');
                if (submitBtn) {
                    submitBtn.innerHTML = '🤖 Рассчитать оптимальные маршруты';
                    submitBtn.disabled = false;
                }
            }
        }

        // Функция расчета с помощью алгоритма (оставлена для совместимости, но не используется)
        function calculateWithAlgorithm() {
            // Проверка пустых полей
            if (!checkEmptyFields()) {
                alert('❌ Укажите недостающие данные во всех точках погрузки, выгрузки и зарядки');
                return;
            }
            
            // Проверка соответствия типов грузов
            const cargoCheck = checkCargoTypes();
            if (!cargoCheck.valid) {
                alert(`❌ Ошибка, груз "${cargoCheck.missingCargo}" не поставляется`);
                return;
            }
            
            alert('⚙️ Функция расчета с помощью алгоритма находится в разработке');
            // Здесь будет реализация алгоритма расчета маршрутов
        }
