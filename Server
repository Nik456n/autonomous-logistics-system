@app.route('/optimize-logistics', methods=['POST', 'OPTIONS'])
def optimize_logistics():
    """
    POST /optimize-logistics

    Основной эндпоинт: принимает JSON с описанием планировки цеха
    и возвращает сгенерированный GigaChat JavaScript-класс RobotController.

    Если GIGACHAT_ENABLED = False — сразу возвращает fallback-контроллер.

    Request body (JSON):
        Объект factoryData с полями room, warehouse, obstacles, loadingPoints,
        unloadingPoints, chargingPoints, tunnels, robotTypes, additionalDetails.

    Returns:
        JSON: {success, controllerCode, fullResponse, message} при успехе
              {success, error} при ошибке
    """
    if request.method == 'OPTIONS':
        return jsonify({'status': 'ok'}), 200
    try:
        data = request.get_json()
        print("Получены данные для оптимизации логистики")

        if not data:
            return jsonify({
                "success": False,
                "error": "No data provided"
            }), 400

        # Если GigaChat отключён — возвращаем резервный контроллер без обращения к API
        if not GIGACHAT_ENABLED:
            print("🔴 GigaChat отключен, возвращаем резервный контроллер")
            return jsonify({
                "success": True,
                "controllerCode": get_fallback_controller_code(),
                "fullResponse": "GIGACHAT_OFFLINE: Используется резервный контроллер",
                "message": "GigaChat временно отключен, используется базовая логика"
            })

        # Получаем OAuth-токен и формируем запрос к GigaChat
        token = get_token()
        if not token:
            return jsonify({
                "success": False,
                "error": "Не удалось получить токен аутентификации от GigaChat"
            }), 500

        # Строим промпт из данных цеха и отправляем в GigaChat
        prompt = build_logistics_prompt(data)
        print("Сгенерирован промпт для GigaChat")

        response = get_chat_completion(token, prompt)

        if not response:
            return jsonify({
                "success": False,
                "error": "Таймаут или ошибка соединения с GigaChat"
            }), 500

        if response.status_code != 200:
            print(f"Ошибка GigaChat: {response.status_code} - {response.text}")
            return jsonify({
                "success": False,
                "error": f"Ошибка запроса к GigaChat: {response.status_code}",
                "details": response.text
            }), 500

        # Извлекаем JS-код из markdown-ответа GigaChat
        result = response.json()
        giga_response = result['choices'][0]['message']['content']
        js_code = extract_js_code(giga_response)

        print("Успешно получен ответ от GigaChat")

        return jsonify({
            "success": True,
            "controllerCode": js_code,
            "fullResponse": giga_response,
            "message": "Логика движения роботов сгенерирована успешно"
        })

    except Exception as e:
        print(f"Ошибка сервера: {str(e)}")
        import traceback
        traceback.print_exc()

        return jsonify({
            "success": False,
            "error": f"Внутренняя ошибка сервера: {str(e)}"
        }), 500

