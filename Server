def extract_js_code(response_text):
    """
    Извлекает JavaScript-код из ответа GigaChat, удаляя markdown-обёртку.

    Последовательно пробует паттерны ```javascript, ```js, ``` и
    возвращает «сырой» текст, если ни один не сработал.

    Args:
        response_text (str): Полный текстовый ответ от GigaChat.

    Returns:
        str: Чистый JavaScript-код без markdown-разметки.
    """
    patterns = [
            r'```javascript\s*(.*?)\s*```',
            r'```js\s*(.*?)\s*```',
            r'```\s*(.*?)\s*```',
             ]

    for pattern in patterns:
            match = re.search(pattern, response_text, re.DOTALL)
            if match:
                return match.group(1).strip()

    return response_text.strip()


def get_fallback_controller_code():
    """
    Возвращает базовый JavaScript-контроллер роботов для работы без GigaChat.

    Используется когда GIGACHAT_ENABLED = False или при ошибке подключения.
    Контроллер инициализирует роботов из точек зарядки и циклически
    переключает их статусы как заглушку — без реального движения.

    Returns:
        str: JavaScript-код класса RobotController (fallback-версия).
    """
    return """
class RobotController {
    constructor(factoryData) {
        this.data = factoryData;
        this.robots = [];
        this.orders = [];
        this.cycleCount = 0;
        this.setupRobots();
        this.generateInitialOrders();
    }

    setupRobots() {
        // Базовая инициализация роботов для резервного контроллера
        if (this.data.chargingPoints && this.data.chargingPoints.length > 0) {
            let robotIdCounter = 1;
            // Перебираем заданные типы роботов
            for (const robotType of this.data.robotTypes || []) {
                // Если anyCount=true — GigaChat должен оптимизировать кол-во,
                // в fallback-режиме создаём по 1 роботу каждого типа
                const count = robotType.anyCount ? 1 : (robotType.count || 0);
                for (let i = 0; i < count; i++) {
                    const chargingPoint = this.data.chargingPoints[0]; // Простейшее распределение: все на первую точку
                    this.robots.push({
                        id: robotIdCounter++,
                        type: robotType.type,
                        position: [...chargingPoint.coordinates],
                        battery: 100,
                        status: 'ready',
                        currentOrder: null,
                        targetPosition: null,
                        path: [],
                        currentTunnel: null
                    });
                }
            }
            // Если типы роботов не заданы — создаём одного дефолтного
            if (this.robots.length === 0 && this.data.chargingPoints.length > 0) {
                const chargingPoint = this.data.chargingPoints[0];
                this.robots.push({
                    id: robotIdCounter++,
                    type: 'DefaultRobot',
                    position: [...chargingPoint.coordinates],
                    battery: 100,
                    status: 'ready',
                    currentOrder: null,
                    targetPosition: null,
                    path: [],
                    currentTunnel: null
                });
            }
        }
        console.log(`[Fallback] Initialized ${this.robots.length} robots.`);
    }

    generateInitialOrders() {
        // Заглушка — реальная генерация заказов выполняется GigaChat-контроллером
        console.log("[Fallback] Generating initial orders (stub).");
    }

    update() {
        this.cycleCount++;
        // Простой цикл статусов для визуализации работы в fallback-режиме
        for (const robot of this.robots) {
            if (robot.status === 'ready') {
                robot.status = 'moving_to_load_stub';
            } else if (robot.status === 'moving_to_load_stub') {
                robot.status = 'loading_stub';
            } else if (robot.status === 'loading_stub') {
                robot.status = 'moving_to_unload_stub';
            } else if (robot.status === 'moving_to_unload_stub') {
                robot.status = 'unloading_stub';
            } else if (robot.status === 'unloading_stub') {
                robot.status = 'moving_to_charge_stub';
            } else if (robot.status === 'moving_to_charge_stub') {
                robot.status = 'charging_stub';
            } else if (robot.status === 'charging_stub') {
                // Быстрая «зарядка» в fallback — сразу 100%
                robot.battery = 100;
                robot.status = 'ready';
            }
        }
        return this.getRobotStates();
    }

    // Заглушки основных методов контроллера
    updateRobotPositions() { /* stub */ }
    checkOrderCompletion() { /* stub */ }
    assignNewOrders() { /* stub */ }
    handleBatteryManagement() { /* stub */ }
    collisionAvoidance() { /* stub */ }
    findOptimalPath(start, end, robot) { return []; /* stub */ }

    getRobotStates() {
        return {
            robots: this.robots.map(robot => ({
                id: robot.id,
                type: robot.type,
                position: robot.position,
                battery: robot.battery,
                status: robot.status,
                currentOrder: robot.currentOrder,
                targetPosition: robot.targetPosition,
                currentTunnel: robot.currentTunnel
            })),
            cycle: this.cycleCount,
            timestamp: Date.now()
        };
    }
