def format_obstacles_detailed(obstacles):
    """
    Форматирует список препятствий. Различает два типа:
    - Препятствия с площадью (withArea=True): выводит центр полигона.
    - Перегородки (withArea=False): выводит первую и последнюю точку линии.

    Args:
        obstacles (list): Список словарей с полями id, coordinates, withArea.

    Returns:
        str: Многострочная строка с описанием каждого препятствия.
    """
    if not obstacles:
        return "Препятствия не определены"

    result = []
    for obstacle in obstacles:
        obs_type = "Препятствие" if obstacle.get('withArea') else "Перегородка"
        coords = obstacle.get('coordinates', [])

        if coords:
            if obstacle.get('withArea'):
                # Для полигональных препятствий — вычисляем центр
                center_x = sum(x for x, y in coords) / len(coords)
                center_y = sum(y for x, y in coords) / len(coords)
                result.append(
                    f"{obs_type} {obstacle.get('id', '?')}: {len(coords)} точек, центр ({center_x:.1f}, {center_y:.1f})")
            else:
                # Для линейных перегородок — первая и последняя точка
                first_point = coords[0]
                last_point = coords[-1]
                result.append(
                    f"{obs_type} {obstacle.get('id', '?')}: {len(coords)} точек, от ({first_point[0]:.1f}, {first_point[1]:.1f}) до ({last_point[0]:.1f}, {last_point[1]:.1f})")
        else:
            result.append(f"{obs_type} {obstacle.get('id', '?')}: координаты не указаны")

    return "\n".join(result)


def format_tunnels_detailed(tunnels):
    """
    Форматирует список тоннелей. Тоннели — оптимизированные маршруты между
    базой/складом и точками погрузки. Показывает направление, материал и крайние точки.

    Args:
        tunnels (list): Список словарей с полями id, points, materialType,
                        startsFrom, targetLoadingPoint.

    Returns:
        str: Многострочная строка с описанием каждого тоннеля.
    """
    if not tunnels:
        return "Тоннели не определены"

    result = []
    for tunnel in tunnels:
        points = tunnel.get('points', [])
        material_type = tunnel.get('materialType', 'не указан')
        starts_from = tunnel.get('startsFrom', 'неизвестно')
        target_loading_point = tunnel.get('targetLoadingPoint')

        # Определяем направление тоннеля по точке старта
        if starts_from == 'warehouse':
            direction = f"🏬 Склад → 📤 П{target_loading_point}"
        else:
            direction = "🏠 База → 🏬 Склад"

        if points:
            start = points[0]
            end = points[-1]
            result.append(
                f"Т{tunnel.get('id', '?')}: {direction} | Материал: {material_type} | {len(points)} точек, от ({start['x']:.1f}, {start['y']:.1f}) до ({end['x']:.1f}, {end['y']:.1f})")
        else:
            result.append(f"Т{tunnel.get('id', '?')}: {direction} | Материал: {material_type} | точек нет")

    return "\n".join(result)


def format_robots_detailed(robot_types):
    """
    Форматирует парк роботов. Если anyCount=True, количество роботов
    определяется GigaChat автоматически. Иначе — используется заданное число.

    Args:
        robot_types (list): Список словарей с полями type, count, anyCount.

    Returns:
        str: Многострочная строка с описанием каждого типа роботов и суммой.
    """
    if not robot_types:
        return "Роботы не определены"

    result = []
    total_robots = 0

    for i, robot in enumerate(robot_types):
        robot_type = robot.get('type', 'любой')
        count = robot.get('count', 0)
        any_count = robot.get('anyCount', True)

        if any_count:
            result.append(f"Робот {i + 1}: Тип '{robot_type}' - количество оптимизируется GigaChat")
        else:
            result.append(f"Робот {i + 1}: Тип '{robot_type}' - {count} шт.")
            total_robots += count

    if total_robots > 0:
        result.append(f"---\nВсего роботов: {total_robots} шт.")

    return "\n".join(result)


def build_logistics_prompt(factory_data):
    """
    Строит детальный промпт для GigaChat на основе данных о планировке цеха.

    Промпт включает полную карту предприятия (склад, точки погрузки/выгрузки,
    зарядки, препятствия, тоннели, парк роботов) и требования к генерируемому
    JavaScript-классу RobotController.

    Args:
        factory_data (dict): Полный объект конфигурации цеха из Constructor.

    Returns:
        str: Готовый промпт для отправки в GigaChat.
    """

    room = factory_data.get('room', {})
    warehouse = factory_data.get('warehouse')
    base_point = factory_data.get('basePoint', {})
    obstacles = factory_data.get('obstacles', [])
    loading_points = factory_data.get('loadingPoints', [])
    unloading_points = factory_data.get('unloadingPoints', [])
    charging_points = factory_data.get('chargingPoints', [])
    tunnels = factory_data.get('tunnels', [])
    robot_types = factory_data.get('robotTypes', [])
    additional_details = factory_data.get('additionalDetails', '')

    prompt = f"""Ты - система управления логистикой автономных роботов-перевозчиков на производственном цехе.

КОНТЕКСТ:
Проектируется система непрерывного движения роботов в цехе размером {room.get('length', 50)}x{room.get('width', 30)} метров.
Производство работает 24/7 без остановки.

ВАЖНЫЕ ТРЕБОВАНИЯ К КОДУ:
1. Роботы НЕ МОГУТ проходить сквозь препятствия и стены
2. Роботы НЕ МОГУТ заезжать на территорию склада (кроме точек зарядки на складе)
3. Каждый робот должен выполнять полный цикл: Зарядка → Погрузка → Доставка → Выгрузка → Возврат на зарядку
4. Типы грузов должны совпадать между точками погрузки и выгрузки
5. Скорость роботов: 1 м/с = 0.1 м за цикл (при обновлении каждые 100мс)
6. Роботы могут использовать тоннели для оптимизации маршрутов

ПОЛНАЯ КАРТА ПРЕДПРИЯТИЯ:

РАЗМЕРЫ ЦЕХА: {room.get('length', 50)}x{room.get('width', 30)}м

БАЗОВАЯ ТОЧКА (начало маршрутов):
{format_base_point(base_point)}

СКЛАД (область хранения):
{format_warehouse_detailed(warehouse)}

ТОЧКИ ПОГРУЗКИ (источники грузов):
{format_loading_points_detailed(loading_points)}

ТОЧКИ ВЫГРУЗКИ (приемники грузов):
{format_unloading_points_detailed(unloading_points)}

ТОЧКИ ЗАРЯДКИ (энергия для роботов):
{format_charging_points_detailed(charging_points)}

ПРЕПЯТСТВИЯ (ограничения движения):
{format_obstacles_detailed(obstacles)}

ТОННЕЛИ (оптимизированные маршруты):
{format_tunnels_detailed(tunnels)}

ПАРК РОБОТОВ (исполнители):
{format_robots_detailed(robot_types)}

ДОПОЛНИТЕЛЬНЫЕ ТРЕБОВАНИЯ:
{additional_details if additional_details else "Стандартные условия работы"}

КОНКРЕТНАЯ ЗАДАЧА:
Создать алгоритм НЕПРЕРЫВНОГО движения роботов в бесконечном цикле производства.

КОНКРЕТНЫЕ ТРЕБОВАНИЯ К АЛГОРИТМУ:
1. Роботы начинают из точек зарядки в статусе 'ready'
2. Бесконечный цикл для каждого робота:
   - Зарядка (charging) →
   - Движение к погрузке (moving_to_load) →
   - Погрузка (loading, 2 секунды) →
   - Движение к выгрузке (moving_to_unload) →
   - Выгрузка (unloading, 2 секунды) →
   - Возврат на зарядку (moving_to_charge)
3. Учет приоритетов доставки (срочные заказы)
4. ОБЯЗАТЕЛЬНО обходить препятствия и перегородки
5. Роботы НЕ МОГУТ проходить через стены, склад или другие препятствия
6. Балансировка нагрузки между роботами
7. Учет состояния батареи и автоматическая зарядка при <30%
8. Минимизация времени простоя
9. Избегание столкновений между роботами
10. Учет типа груза - робот берет заказ ТОЛЬКО если тип груза в точке погрузки совпадает с типом в точке выгрузки
11. Использование тоннелей для оптимизации маршрутов между складом и точками погрузки

СТРУКТУРА ДАННЫХ factoryData (ИСПОЛЬЗУЙ ТОЛЬКО ЭТИ ИМЕНА):
- room: {{length, width, height}}
- basePoint: {{coordinates: [x, y]}}
- warehouse: {{coordinates: [[x1,y1], [x2,y2], ...]}} (многоугольник)
- obstacles: массив с {{id, coordinates: [[x1,y1], [x2,y2], ...], withArea: boolean}}
- loadingPoints: массив с {{id, coordinates: [x,y], cargoType, totalWeight, unitWeight}}
- unloadingPoints: массив с {{id, coordinates: [x,y], requirements: [{{cargoType, maxCapacity, totalWeight}}]}}
- chargingPoints: массив с {{id, coordinates: [x,y], chargingPlaces}}
- tunnels: массив с {{id, points: [{{x, y}}], materialType, startsFrom, targetLoadingPoint, endsAt}}
- robotTypes: массив с {{type, count, anyCount}}

