def get_token():
    """
    Получение токена доступа для GigaChat API через OAuth2.

    Кодирует CLIENT_ID и CLIENT_SECRET в Base64 и отправляет
    запрос к эндпоинту авторизации Сбера.

    Returns:
        str | None: access_token при успехе, None при ошибке.
    """
    credentials = f"{CLIENT_ID}:{CLIENT_SECRET}"
    encoded_credentials = base64.b64encode(credentials.encode('utf-8')).decode('utf-8')
    rq_uid = str(uuid.uuid4())

    headers = {
        'Content-Type': 'application/x-www-form-urlencoded',
        'Accept': 'application/json',
        'RqUID': rq_uid,
        'Authorization': f'Basic {encoded_credentials}'
    }
    data = {'scope': 'GIGACHAT_API_PERS'}
    url = "https://ngw.devices.sberbank.ru:9443/api/v2/oauth"

    try:
        response = requests.post(url, headers=headers, data=data, verify=False)
        if response.status_code == 200:
            return response.json()['access_token']
        else:
            print("Ошибка при получении токена:", response.status_code, response.text)
            return None
    except Exception as e:
        print("Исключение при получении токена:", str(e))
        return None


def get_chat_completion(token, user_message):
    """
    Отправка запроса к GigaChat API и получение ответа модели.

    Args:
        token (str): Bearer-токен доступа, полученный через get_token().
        user_message (str): Текст промпта для генерации кода контроллера.

    Returns:
        requests.Response | None: Объект ответа при успехе, None при ошибке.
    """
    url = "https://gigachat.devices.sberbank.ru/api/v1/chat/completions"
    payload = {
        "model": "GigaChat",
        "messages": [{"role": "user", "content": user_message}],
        "temperature": 0.7,
        "top_p": 0.9,
        "n": 1,
        "stream": False,
        "max_tokens": 4000,
        "repetition_penalty": 1
    }
    headers = {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'Authorization': f'Bearer {token}'
    }

    try:
        response = requests.post(url, headers=headers, data=json.dumps(payload), verify=False, timeout=30)
        return response
    except Exception as e:
        print("Исключение при запросе к GigaChat:", str(e))
        return None


def format_base_point(base_point):
    """
    Форматирует базовую точку (начальную позицию роботов) в читаемую строку.

    Args:
        base_point (dict): Словарь с ключом 'coordinates': [x, y].

    Returns:
        str: Строка с координатами или сообщение об отсутствии данных.
    """
    if not base_point or 'coordinates' not in base_point:
        return "Не определена"

    coords = base_point['coordinates']
    return f"Координаты: ({coords[0]:.1f}, {coords[1]:.1f})"


def format_warehouse_detailed(warehouse):
    """
    Детально форматирует зону склада: количество точек, координаты и центр полигона.

    Args:
        warehouse (dict): Словарь с ключом 'coordinates': [[x1,y1], [x2,y2], ...].

    Returns:
        str: Многострочное описание склада или сообщение об ошибке.
    """
    if not warehouse or 'coordinates' not in warehouse:
        return "Склад не определен"

    coords = warehouse['coordinates']
    points_str = ", ".join([f"({x:.1f}, {y:.1f})" for x, y in coords])

    # Вычисляем геометрический центр полигона склада
    center_x = sum(x for x, y in coords) / len(coords)
    center_y = sum(y for x, y in coords) / len(coords)

    return f"Область склада: {len(coords)} точек\nКоординаты: {points_str}\nЦентр: ({center_x:.1f}, {center_y:.1f})"


def format_loading_points_detailed(loading_points):
    """
    Форматирует список точек погрузки с типом груза и весовыми параметрами.

    Args:
        loading_points (list): Список словарей с полями id, coordinates, cargoType,
                               totalWeight, unitWeight.

    Returns:
        str: Многострочная строка с описанием каждой точки погрузки.
    """
    if not loading_points:
        return "Точки погрузки не определены"

    result = []
    for point in loading_points:
        coords = point.get('coordinates', [0, 0])
        cargo_type = point.get('cargoType', 'не указан')
        total_weight = point.get('totalWeight', 'не указан')
        unit_weight = point.get('unitWeight', 'не указан')

        result.append(
            f"П{point.get('id', '?')}: ({coords[0]:.1f}, {coords[1]:.1f}) | Груз: {cargo_type} | Общий вес: {total_weight} | Вес единицы: {unit_weight}")

    return "\n".join(result)


