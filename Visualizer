        // Получаем данные из localStorage
        function loadResponseData() {
            const responseData = localStorage.getItem('gigaChatResponse');
            
            if (!responseData) {
                showError('Нет данных ответа от GigaChat. Вернитесь на страницу инженера и отправьте запрос.');
                return null;
            }
            
            try {
                return JSON.parse(responseData);
            } catch (error) {
                showError('Ошибка при разборе данных: ' + error.message);
                return null;
            }
        }

        // Показываем статус
        function showStatus(message, type) {
            const statusPanel = document.getElementById('statusPanel');
            statusPanel.innerHTML = `<div class="status ${type}">${message}</div>`;
        }

        // Показываем ошибку
        function showError(message) {
            showStatus('❌ ' + message, 'error');
        }

        // Показываем успех
        function showSuccess(message) {
            showStatus('✅ ' + message, 'success');
        }

        // Показываем предупреждение
        function showWarning(message) {
            showStatus('⚠️ ' + message, 'warning');
        }

        // Форматирование координат для отображения
        function formatCoordinates(coords) {
            if (!coords) return '';
            if (Array.isArray(coords[0])) {
                return coords.map(coord => `[${coord[0]?.toFixed(1) || 0}, ${coord[1]?.toFixed(1) || 0}]`).join(', ');
            }
            return `[${coords[0]?.toFixed(1) || 0}, ${coords[1]?.toFixed(1) || 0}]`;
        }

        // Форматирование точек тоннеля
        function formatTunnelPoints(points) {
            if (!points || !points.length) return '';
            return points.map(point => `[${point.x?.toFixed(1) || 0}, ${point.y?.toFixed(1) || 0}]`).join(' → ');
        }

        // Создание элемента информации
        function createInfoItem(label, value, isCoordinates = false) {
            if (!value || (Array.isArray(value) && value.length === 0)) {
                return `<div class="info-item">
                    <div class="info-label">${label}</div>
                    <div class="info-value empty-data">Не указано</div>
                </div>`;
            }

            let valueHtml;
            if (isCoordinates) {
                if (typeof value === 'string') {
                    const coordsArray = value.split(', ');
                    valueHtml = `<div class="coordinates-list">${
                        coordsArray.map(coord => 
                            `<div class="coordinate-pair">${coord}</div>`
                        ).join('')
                    }</div>`;
                } else if (Array.isArray(value)) {
                    valueHtml = `<div class="coordinates-list">${
                        value.map(coord => 
                            `<div class="coordinate-pair">${coord}</div>`
                        ).join('')
                    }</div>`;
                } else {
                    valueHtml = `<div class="info-value">${value}</div>`;
                }
            } else {
                valueHtml = `<div class="info-value">${value}</div>`;
            }

            return `<div class="info-item">
                <div class="info-label">${label}</div>
                ${valueHtml}
            </div>`;
        }

