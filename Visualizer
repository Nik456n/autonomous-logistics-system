                        }
                    });
                    
                    console.log(`✅ Отправлено на зарядку: ${sentCount} роботов`);
                    return sentCount;
                },

                // Вспомогательные методы
                replanPath(robot) {
                    // Логика перепланирования пути
                    if (!robot.currentOrder) return;
                    
                    let target = null;
                    if (robot.status === 'moving_to_load') {
                        target = robot.currentOrder.source;
                    } else if (robot.status === 'moving_to_unload') {
                        target = robot.currentOrder.destination;
                    } else if (robot.status === 'moving_to_charge') {
                        target = robot.targetPosition;
                    }
                    
                    if (target) {
                        const newPath = this.findPath(robot.position, target);
                        if (newPath && newPath.length > 1) {
                            robot.path = newPath;
                            robot.currentPathIndex = 1;
                            robot.targetPosition = robot.path[robot.currentPathIndex];
                            robot.failedPathAttempts = 0;
                        }
                    }
                },

                findAlternativePath(robot) {
                    // Логика поиска альтернативного пути
                    const dx = robot.targetPosition[0] - robot.position[0];
                    const dy = robot.targetPosition[1] - robot.position[1];
                    const baseAngle = Math.atan2(dy, dx);
                    
                    const angles = [Math.PI/4, -Math.PI/4, Math.PI/2, -Math.PI/2, 3*Math.PI/4, -3*Math.PI/4];
                    let bestDirection = null;
                    let bestScore = -Infinity;
                    
                    for (const angleOffset of angles) {
                        const testAngle = baseAngle + angleOffset;
                        const distance = 3;
                        const testPosition = [
                            robot.position[0] + Math.cos(testAngle) * distance,
                            robot.position[1] + Math.sin(testAngle) * distance
                        ];
                        
                        if (!this.checkCollision(testPosition)) {
                            const toTargetDx = robot.targetPosition[0] - testPosition[0];
                            const toTargetDy = robot.targetPosition[1] - testPosition[1];
                            const toTargetDistance = Math.sqrt(toTargetDx * toTargetDx + toTargetDy * toTargetDy);
                            
                            const score = 1.0 / (toTargetDistance + 0.1);
                            
                            if (score > bestScore) {
                                bestScore = score;
                                bestDirection = testAngle;
                            }
                        }
                    }
                    
                    if (bestDirection !== null) {
                        const distance = 2;
                        robot.targetPosition = [
                            robot.position[0] + Math.cos(bestDirection) * distance,
                            robot.position[1] + Math.sin(bestDirection) * distance
                        ];
                        return;
                    }
                    
                    const randomAngle = Math.random() * Math.PI * 2;
                    const distance = 2;
                    robot.targetPosition = [
                        robot.position[0] + Math.cos(randomAngle) * distance,
                        robot.position[1] + Math.sin(randomAngle) * distance
                    ];
                },

                // Проверка столкновений с параметром буфера
                checkCollision(position, buffer = 2.0) {
                    if (position[0] < buffer || position[0] > (this.data.room?.length || 50) - buffer || 
                        position[1] < buffer || position[1] > (this.data.room?.width || 30) - buffer) {
                        return true;
                    }
                    
                    if (this.data.warehouse && this.data.warehouse.coordinates) {
                        if (this.isPointInPolygon(position, this.data.warehouse.coordinates)) {
                            return true;
                        }
                        if (this.distanceToPolygon(position, this.data.warehouse.coordinates) < buffer) {
                            return true;
                        }
                    }
                    
                    if (this.data.obstacles) {
                        for (const obstacle of this.data.obstacles) {
                            if (obstacle.withArea && obstacle.coordinates) {
                                if (this.isPointInPolygon(position, obstacle.coordinates)) {
                                    return true;
                                }
                                if (this.distanceToPolygon(position, obstacle.coordinates) < buffer) {
                                    return true;
                                }
                            } else if (obstacle.coordinates && obstacle.coordinates.length >= 2) {
                                for (let i = 0; i < obstacle.coordinates.length - 1; i++) {
                                    const p1 = obstacle.coordinates[i];
                                    const p2 = obstacle.coordinates[i + 1];
                                    if (this.pointToLineDistance(position, p1, p2) < buffer) {
                                        return true;
                                    }
                                }
                            }
                        }
                    }
                    
                    return false;
                },
                
                // Расчет расстояния между точками
                calculateDistance(pos1, pos2) {
                    if (!pos1 || !pos2 || pos1.length < 2 || pos2.length < 2) return Infinity;
                    return Math.sqrt(
                        Math.pow(pos1[0] - pos2[0], 2) +
                        Math.pow(pos1[1] - pos2[1], 2)
                    );
                },
                
                // Расстояние от точки до полигона
                distanceToPolygon(point, polygon) {
                    let minDistance = Infinity;
                    
                    for (let i = 0; i < polygon.length; i++) {
                        const p1 = polygon[i];
                        const p2 = polygon[(i + 1) % polygon.length];
                        const distance = this.pointToLineDistance(point, p1, p2);
                        minDistance = Math.min(minDistance, distance);
                    }
                    
                    return minDistance;
                },
                
                // Расстояние от точки до линии
                pointToLineDistance(point, lineStart, lineEnd) {
                    const A = point[0] - lineStart[0];
                    const B = point[1] - lineStart[1];
                    const C = lineEnd[0] - lineStart[0];
                    const D = lineEnd[1] - lineStart[1];
                    
                    const dot = A * C + B * D;
                    const lenSq = C * C + D * D;
                    let param = -1;
                    if (lenSq !== 0) param = dot / lenSq;
                    
                    let xx, yy;
                    
                    if (param < 0) {
                        xx = lineStart[0];
                        yy = lineStart[1];
                    } else if (param > 1) {
                        xx = lineEnd[0];
                        yy = lineEnd[1];
                    } else {
                        xx = lineStart[0] + param * C;
                        yy = lineStart[1] + param * D;
                    }
                    
                    const dx = point[0] - xx;
                    const dy = point[1] - yy;
                    return Math.sqrt(dx * dx + dy * dy);
                },
                
                // Проверка точки в полигоне
                isPointInPolygon(point, polygon) {
                    let inside = false;
                    for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
                        const xi = polygon[i][0], yi = polygon[i][1];
                        const xj = polygon[j][0], yj = polygon[j][1];
                        
                        const intersect = ((yi > point[1]) !== (yj > point[1])) &&
                            (point[0] < (xj - xi) * (point[1] - yi) / (yj - yi) + xi);
                        if (intersect) inside = !inside;
                    }
                    return inside;
                },

                // Инициализация прогресса доставки
                initializeDeliveryProgress() {
                    this.deliveryProgress.clear();
                    const unloadingPoints = this.data.unloadingPoints || [];
                    
                    unloadingPoints.forEach(point => {
                        if (point.requirements) {
                            point.requirements.forEach(req => {
                                const key = `${point.id}_${req.cargoType}`;
                                this.deliveryProgress.set(key, {
                                    unloadingPointId: point.id,
                                    cargoType: req.cargoType,
                                    totalRequired: req.totalWeight || 0,
                                    delivered: 0,
                                    maxPerDelivery: req.maxCapacity || 250,
                                    completed: false,
                                    assignedRobots: new Set()
                                });
                            });
                        }
                    });
                    
                    this.totalDeliveries = this.deliveryProgress.size;
                    this.completedDeliveries = 0;
                    
                    console.log('📦 Инициализирован прогресс доставки:', this.deliveryProgress.size, 'типов грузов');
                },

