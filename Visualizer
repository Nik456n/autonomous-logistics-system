                // ФУНКЦИЯ ДЛЯ ПРИНУДИТЕЛЬНОЙ ОТПРАВКИ РОБОТОВ НА ЗАРЯДКУ
                resetRobotsToCharging() {
                    console.log('🔄 Принудительный сброс всех роботов на зарядку');
                    
                    let sentCount = 0;
                    this.robots.forEach(robot => {
                        // Если робот не заряжается и не едет на зарядку
                        if (robot.status !== 'charging' && robot.status !== 'moving_to_charge') {
                            // Сбрасываем все задания
                            robot.currentOrder = null;
                            robot.currentDelivery = null;
                            robot.cargo = null;
                            robot.status = 'ready';
                            robot.isAtTargetPoint = false;
                            robot.lastTargetType = null;
                            robot.targetReachedTime = null;
                            
                            // ОСВОБОЖДАЕМ предыдущую точку зарядки
                            if (robot.targetChargingPointId) {
                                console.log(`🔓 Робот R${robot.id} освобождает точку ${robot.targetChargingPointId}`);
                                robot.targetChargingPointId = null;
