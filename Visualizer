        // Инициализация визуализации
        function initializeVisualization() {
            if (!factoryData) return;

            canvas = document.getElementById('visualizationCanvas');
            ctx = canvas.getContext('2d');
            
            // Устанавливаем размеры цеха
            roomLength = factoryData.room?.length || 50;
            roomWidth = factoryData.room?.width || 30;
            
            setupCanvasSize();
            setupEventListeners();
            centerMap();
            startTunnelAnimation();
            
            // Создаем панель статистики
            createRobotStatsPanel();
        }

        // Настройка размера canvas
        function setupCanvasSize() {
            if (window.innerWidth <= 768) {
                canvas.width = window.innerWidth * 0.95;
                canvas.height = 400;
            } else {
                canvas.width = 1200;
                canvas.height = 600;
            }
        }

        // Настройка обработчиков событий
        function setupEventListeners() {
            // Кнопки масштабирования
            document.getElementById('zoomInBtn').addEventListener('click', () => zoomAtCenter(1.2));
            document.getElementById('zoomOutBtn').addEventListener('click', () => zoomAtCenter(0.8));
            
            // Обработка событий мыши
            canvas.addEventListener('mousemove', handleMouseMove);
            canvas.addEventListener('wheel', handleWheel);
            canvas.addEventListener('mousedown', startDragging);
            canvas.addEventListener('mouseup', stopDragging);
            canvas.addEventListener('mouseleave', stopDragging);
            
            // Изменение размера окна
            window.addEventListener('resize', function() {
                setupCanvasSize();
                updateVisualization();
            });
        }

        // Центрирование карты
        function centerMap() {
            const scale = baseScale * userZoom;
            offsetX = (canvas.width - roomLength * scale) / 2;
            offsetY = (canvas.height - roomWidth * scale) / 2;
            updateVisualization();
        }

        // Сброс масштаба
        function resetZoom() {
            userZoom = 1;
            updateZoomDisplay();
            centerMap();
        }

        // Анимация тоннелей
        function startTunnelAnimation() {
            function animate() {
                tunnelAnimationOffset = (tunnelAnimationOffset + 0.02) % 1;
                updateVisualization();
                requestAnimationFrame(animate);
            }
            animate();
        }

        // Обработка начала перетаскивания
        function startDragging(event) {
            if (event.button !== 0) return;
            isDragging = true;
            lastX = event.clientX;
            lastY = event.clientY;
            canvas.style.cursor = 'grabbing';
        }

        // Обработка окончания перетаскивания
        function stopDragging() {
            isDragging = false;
            canvas.style.cursor = 'grab';
        }

        // Обработка движения мыши
        function handleMouseMove(event) {
            const rect = canvas.getBoundingClientRect();
            const scale = baseScale * userZoom;
            
            // Обработка перетаскивания
            if (isDragging) {
                const currentX = event.clientX;
                const currentY = event.clientY;
                
                const dx = currentX - lastX;
                const dy = currentY - lastY;
                
                offsetX += dx;
                offsetY += dy;
                
                lastX = currentX;
                lastY = currentY;
                
                updateVisualization();
                return;
            }
            
            // Отображение координат
            const worldCoords = getWorldCoords(event.clientX, event.clientY);
            if (!worldCoords) {
                document.getElementById('coordinatesDisplay').style.display = 'none';
                return;
            }
            
            const { x, y } = worldCoords;
            const display = document.getElementById('coordinatesDisplay');
            display.style.display = 'block';
            display.style.left = (event.clientX + 15) + 'px';
            display.style.top = (event.clientY + 15) + 'px';
            display.textContent = `X: ${x.toFixed(1)}, Y: ${y.toFixed(1)}`;
        }

        // Получение мировых координат
        function getWorldCoords(clientX, clientY) {
            const rect = canvas.getBoundingClientRect();
            const scale = baseScale * userZoom;
            
            const canvasX = clientX - rect.left;
            const canvasY = clientY - rect.top;
            
            if (canvasX < 0 || canvasX > canvas.width || canvasY < 0 || canvasY > canvas.height) {
                return null;
            }
            
            const x = (canvasX - offsetX) / scale;
            const y = roomWidth - (canvasY - offsetY) / scale;
            
            return { x, y };
        }

        // Обработка колесика мыши
        function handleWheel(event) {
            event.preventDefault();
            const rect = canvas.getBoundingClientRect();
            const x = event.clientX - rect.left;
            const y = event.clientY - rect.top;
            
            if (event.deltaY < 0) {
                zoomAt(x, y, 1.2);
            } else {
                zoomAt(x, y, 0.8);
            }
        }

        // Масштабирование относительно точки
        function zoomAt(x, y, factor) {
            const oldZoom = userZoom;
            userZoom = Math.max(0.2, Math.min(5, userZoom * factor));
            
            const worldX = (x - offsetX) / (baseScale * oldZoom);
            const worldY = (y - offsetY) / (baseScale * oldZoom);
            
            offsetX = x - worldX * (baseScale * userZoom);
            offsetY = y - worldY * (baseScale * userZoom);
            
            updateZoomDisplay();
            updateVisualization();
        }

        // Масштабирование относительно центра
        function zoomAtCenter(factor) {
            const rect = canvas.getBoundingClientRect();
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            zoomAt(centerX, centerY, factor);
        }

        // Обновление отображения уровня масштаба
        function updateZoomDisplay() {
            document.getElementById('zoomLevel').textContent = Math.round(userZoom * 100) + '%';
        }

        // Обновление визуализации
        function updateVisualization() {
            if (!factoryData) return;

            // Рассчитываем базовый масштаб
            baseScale = Math.min(
                (canvas.width - 40) / roomLength,
                (canvas.height - 40) / roomWidth
            );
            
            const scale = baseScale * userZoom;
            
            // Очищаем canvas
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Рисуем сетку
            drawGrid(scale);
            
            // Рисуем контур цеха
            ctx.strokeStyle = '#00b4d8';
            ctx.lineWidth = 3;
            ctx.strokeRect(offsetX, offsetY, roomLength * scale, roomWidth * scale);
            
            // Рисуем объекты в правильном порядке
            drawWarehouse(scale);
            drawObstacles(scale);
            drawTunnels(scale);
            drawBasePoint(scale);
            drawLoadingPoints(scale);
            drawUnloadingPoints(scale);
            drawChargingPoints(scale);
            
            // Рисуем роботов поверх всего
            if (robotStates && robotStates.robots) {
                drawRobots(scale);
            }
            
            // Обновляем статус анимации
            updateAnimationStatus();
            
            // Обновляем статистику
            updateRobotStats();
            
            // Обновляем статистику производительности
            updatePerformanceStats();
        }

        // Рисуем сетку
        function drawGrid(scale) {
            const gridSize = roomLength > 100 ? 10 : 5;
            
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
            ctx.lineWidth = 1;
            
            // Вертикальные линии
            for (let x = 0; x <= roomLength; x += gridSize) {
                ctx.beginPath();
                ctx.moveTo(offsetX + x * scale, offsetY);
                ctx.lineTo(offsetX + x * scale, offsetY + roomWidth * scale);
                ctx.stroke();
            }
            
            // Горизонтальные линии
            for (let y = 0; y <= roomWidth; y += gridSize) {
                ctx.beginPath();
                ctx.moveTo(offsetX, offsetY + y * scale);
                ctx.lineTo(offsetX + roomLength * scale, offsetY + y * scale);
                ctx.stroke();
            }
        }

        // Рисуем склад
        function drawWarehouse(scale) {
            if (!factoryData.warehouse || !factoryData.warehouse.coordinates) return;
            
            const coords = factoryData.warehouse.coordinates;
            
            ctx.fillStyle = 'rgba(102, 170, 255, 0.3)';
            ctx.strokeStyle = '#66aaff';
            ctx.lineWidth = 3;
            
            ctx.beginPath();
            ctx.moveTo(
                offsetX + coords[0][0] * scale,
                offsetY + (roomWidth - coords[0][1]) * scale
            );
            
            for (let i = 1; i < coords.length; i++) {
                ctx.lineTo(
                    offsetX + coords[i][0] * scale,
                    offsetY + (roomWidth - coords[i][1]) * scale
                );
            }
            
            ctx.closePath();
            ctx.fill();
            ctx.stroke();
            
            // Подпись склада
            const centerX = coords.reduce((sum, p) => sum + p[0], 0) / coords.length;
            const centerY = coords.reduce((sum, p) => sum + p[1], 0) / coords.length;
            
            ctx.fillStyle = 'white';
            ctx.font = 'bold 14px Arial';
            ctx.textAlign = 'center';
            ctx.fillText(
                'СКЛАД',
                offsetX + centerX * scale,
                offsetY + (roomWidth - centerY) * scale
            );
        }

        // Рисуем базовую точку
        function drawBasePoint(scale) {
            if (!factoryData.basePoint || !factoryData.basePoint.coordinates) return;
            
            const x = factoryData.basePoint.coordinates[0];
            const y = factoryData.basePoint.coordinates[1];
            
            // Рисуем дом (базовую точку)
            ctx.fillStyle = '#ff6b6b';
            ctx.strokeStyle = '#ff4757';
            ctx.lineWidth = 2;
            
