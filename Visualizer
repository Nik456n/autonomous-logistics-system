        // ИСПРАВЛЕННАЯ ФУНКЦИЯ: Рисуем точки зарядки с отображением занятости
        function drawChargingPoints(scale) {
            if (!factoryData.chargingPoints) return;
            
            factoryData.chargingPoints.forEach(point => {
                const x = point.coordinates[0];
                const y = point.coordinates[1];
                
                // Считаем занятость точки
                let occupied = 0;
                let capacity = point.chargingPlaces || 1;
                
                if (robotController && robotController.robots) {
                    // Роботы, которые уже заряжаются на этой точке
                    const chargingRobotsAtPoint = robotController.robots.filter(r => {
                        if (!r.position || r.status !== 'charging') return false;
                        const distToPoint = robotController.calculateDistance(r.position, point.coordinates);
                        return distToPoint < 1.5;
                    }).length;
                    
                    // Роботы, которые движутся к этой точке
                    const movingToChargeRobots = robotController.robots.filter(r => 
                        r.status === 'moving_to_charge' && 
                        r.targetPosition && 
                        robotController.calculateDistance(r.targetPosition, point.coordinates) < 1.5
                    ).length;
                    
                    // Роботы, которые забронировали эту точку
                    const reservedRobots = robotController.robots.filter(r => {
                        const pointId = point.id || `charge_${point.coordinates[0]}_${point.coordinates[1]}`;
                        return r.targetChargingPointId === pointId && r.id !== robotController.robots.find(rr => rr.id === r.id)?.id;
                    }).length;
                    
                    occupied = chargingRobotsAtPoint + movingToChargeRobots + reservedRobots;
                }
                
                const isFull = occupied >= capacity;
                
                // Меняем цвет в зависимости от загрузки
                ctx.fillStyle = isFull ? '#ff4444' : '#44ff44';
                ctx.strokeStyle = isFull ? '#cc0000' : '#00cc00';
