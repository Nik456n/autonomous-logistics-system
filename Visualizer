        // Рисуем роботы с траекториями движения
        function drawRobots(scale) {
            if (!robotStates || !robotStates.robots) return;
            
            robotStates.robots.forEach(robot => {
                // Преобразуем позицию робота в правильный формат
                let posX, posY;
                if (Array.isArray(robot.position)) {
                    posX = robot.position[0];
                    posY = robot.position[1];
                } else {
                    posX = robot.position.x;
                    posY = robot.position.y;
                }
                
                // Определяем цвет робота в зависимости от типа
                const spec = ROBOT_SPECS[robot.type] || ROBOT_SPECS["T-500"];
                let color = spec?.color || '#4e94c9';
                let borderColor = '#2d4a5a';
                
                // Дополнительные цвета по статусу
                if (robot.status === 'charging') {
                    color = '#4ec94e';
                    borderColor = '#2d5a2d';
                } else if (robot.status === 'loading') {
                    color = '#c94e4e';
                    borderColor = '#5a2d2d';
                } else if (robot.status === 'unloading') {
                    color = '#c9c94e';
                    borderColor = '#5a5a2d';
                }
                
                // Рисуем траекторию движения (пунктирная линия к цели)
                if (robot.targetPosition && (robot.status.includes('moving') || robot.status === 'busy')) {
                    let targetX, targetY;
                    if (Array.isArray(robot.targetPosition)) {
                        targetX = robot.targetPosition[0];
                        targetY = robot.targetPosition[1];
                    } else {
                        targetX = robot.targetPosition.x;
                        targetY = robot.targetPosition.y;
                    }
                    
                    // Пунктирная линия к цели
                    ctx.strokeStyle = 'rgba(255, 255, 255, 0.6)';
                    ctx.lineWidth = 2;
                    ctx.setLineDash([5, 5]);
                    
                    ctx.beginPath();
                    ctx.moveTo(
                        offsetX + posX * scale,
                        offsetY + (roomWidth - posY) * scale
                    );
                    ctx.lineTo(
                        offsetX + targetX * scale,
                        offsetY + (roomWidth - targetY) * scale
                    );
                    ctx.stroke();
                    ctx.setLineDash([]);
                    
                    // Треугольник-указатель направления
                    const dx = targetX - posX;
                    const dy = targetY - posY;
                    const angle = Math.atan2(dy, dx);
                    const arrowSize = 8;
                    
                    ctx.fillStyle = 'rgba(255, 255, 0, 0.8)';
                    ctx.beginPath();
                    ctx.moveTo(
                        offsetX + posX * scale,
                        offsetY + (roomWidth - posY) * scale
                    );
                    ctx.lineTo(
                        offsetX + posX * scale - arrowSize * Math.cos(angle - Math.PI/6),
                        offsetY + (roomWidth - posY) * scale + arrowSize * Math.sin(angle - Math.PI/6)
                    );
                    ctx.lineTo(
                        offsetX + posX * scale - arrowSize * Math.cos(angle + Math.PI/6),
                        offsetY + (roomWidth - posY) * scale + arrowSize * Math.sin(angle + Math.PI/6)
                    );
                    ctx.closePath();
                    ctx.fill();
                }
                
                // Индикатор застревания (красная пульсирующая рамка)
                if (robot.stuckDetection && robot.stuckDetection.isStuck) {
                    const pulse = Math.sin(Date.now() / 200) * 0.5 + 0.5;
                    ctx.strokeStyle = `rgba(255, 0, 0, ${0.7 + pulse * 0.3})`;
                    ctx.lineWidth = 4;
                    ctx.setLineDash([8, 4]);
                    ctx.beginPath();
                    ctx.arc(
                        offsetX + posX * scale,
                        offsetY + (roomWidth - posY) * scale,
                        18, 0, Math.PI * 2
                    );
                    ctx.stroke();
                    ctx.setLineDash([]);
                    
                    // Текст "ЗАСТРЯЛ" с пульсацией
                    ctx.fillStyle = `rgba(255, 0, 0, ${0.8 + pulse * 0.2})`;
                    ctx.font = 'bold 11px Arial';
                    ctx.textAlign = 'center';
                    ctx.fillText(
                        'ЗАСТРЯЛ',
                        offsetX + posX * scale,
                        offsetY + (roomWidth - posY) * scale + 28
                    );
                    
                    // Индикатор времени застревания
                    const stuckTime = robot.stuckDetection.stuckStartTime ? 
                        Math.round((Date.now() - robot.stuckDetection.stuckStartTime) / 1000) : 0;
                    ctx.fillStyle = 'rgba(255, 100, 100, 0.9)';
                    ctx.font = '9px Arial';
                    ctx.fillText(
                        `${stuckTime}сек`,
                        offsetX + posX * scale,
                        offsetY + (roomWidth - posY) * scale + 40
                    );
                }
                
                // Рисуем робота (треугольник вместо квадрата)
                const robotSize = 12;
                ctx.fillStyle = color;
                ctx.strokeStyle = borderColor;
                ctx.lineWidth = 2;
                
                // Робот в виде направленного треугольника
                let angle = 0;
                if (robot.targetPosition) {
                    let targetX, targetY;
                    if (Array.isArray(robot.targetPosition)) {
                        targetX = robot.targetPosition[0];
                        targetY = robot.targetPosition[1];
                    } else {
                        targetX = robot.targetPosition.x;
                        targetY = robot.targetPosition.y;
                    }
                    angle = Math.atan2(targetY - posY, targetX - posX);
                }
                
                ctx.beginPath();
                ctx.moveTo(
                    offsetX + posX * scale + robotSize * Math.cos(angle),
                    offsetY + (roomWidth - posY) * scale - robotSize * Math.sin(angle)
                );
                ctx.lineTo(
                    offsetX + posX * scale + robotSize * Math.cos(angle + 2.5),
                    offsetY + (roomWidth - posY) * scale - robotSize * Math.sin(angle + 2.5)
                );
                ctx.lineTo(
                    offsetX + posX * scale + robotSize * Math.cos(angle - 2.5),
                    offsetY + (roomWidth - posY) * scale - robotSize * Math.sin(angle - 2.5)
                );
                ctx.closePath();
                ctx.fill();
                ctx.stroke();
                
                // Индикатор батареи
                const batteryWidth = 8;
                const batteryHeight = 4;
                const batteryLevel = Math.max(0, Math.min(1, (robot.battery || 100) / 100)) * batteryWidth;
                
                ctx.fillStyle = (robot.battery || 100) > 20 ? '#4ec94e' : '#c94e4e';
                ctx.fillRect(
                    offsetX + posX * scale - batteryWidth/2,
                    offsetY + (roomWidth - posY) * scale - robotSize - 8,
                    batteryLevel, batteryHeight
                );
                
                // Подпись робота
                ctx.fillStyle = 'white';
                ctx.font = 'bold 10px Arial';
                ctx.textAlign = 'center';
                ctx.fillText(
                    `R${robot.id}`,
                    offsetX + posX * scale,
                    offsetY + (roomWidth - posY) * scale - robotSize - 12
                );
                
                // Отладочная информация (только при большом масштабе)
                if (userZoom > 0.8) {
                    ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
                    ctx.font = '8px Arial';
                    ctx.textAlign = 'left';
                    ctx.fillText(
                        `${robot.status || 'unknown'}`,
                        offsetX + posX * scale + 8,
                        offsetY + (roomWidth - posY) * scale - 4
                    );
                }
            });
        }

        // Улучшенная функция для исправления кода GigaChat
        function fixGigaChatCode(jsCode) {
            let fixedCode = jsCode;
            
            console.log("🔧 Начинаем исправление кода GigaChat...");
            
            try {
                // 1. Убираем только исполняемые части в конце, оставляя чистый класс
                const patternsToRemove = [
                    /\/\/\s*Пример использования[\s\S]*$/,
                    /\/\/\s*Пример игрового цикла[\s\S]*$/,
                    /const\s+factoryData\s*=\s*\{[\s\S]*?\};\s*$/,
                    /const\s+controller\s*=\s*new\s+RobotController\([^)]*\);\s*$/,
                    /function\s+gameLoop\(\)\s*\{[\s\S]*?\}\s*gameLoop\(\);\s*$/
                ];
                
                patternsToRemove.forEach(pattern => {
                    fixedCode = fixedCode.replace(pattern, '').trim();
                });
                
                // 2. Убираем лишние обратные кавычки если они есть
                fixedCode = fixedCode.replace(/^```javascript|^```js|^```|```$/g, '').trim();
                
                // 3. Проверяем наличие основных методов
                const hasSetupRobots = fixedCode.includes('setupRobots');
                const hasUpdate = fixedCode.includes('update(');
                const hasGetRobotStates = fixedCode.includes('getRobotStates');
                
                if (!hasSetupRobots || !hasUpdate || !hasGetRobotStates) {
                    console.warn('⚠️ Код не содержит обязательные методы, применяем исправление');
                    throw new Error('Недостающие обязательные методы');
                }
                
                console.log("✅ Исправление кода завершено");
                return fixedCode;
                
            } catch (error) {
                console.error('❌ Ошибка при исправлении кода:', error);
                throw new Error('Код GigaChat содержит критические ошибки и не может быть исправлен');
            }
        }

        // УНИВЕРСАЛЬНАЯ СИСТЕМА ТОЧНОГО ПОЗИЦИОНИРОВАНИЯ
        class PrecisionPositioning {
            constructor(controller) {
                this.controller = controller;
                this.positionHistory = new Map();
            }

            // Проверка точного нахождения на точке
            isAtExactPoint(position, targetPoint, tolerance) {
                const dx = Math.abs(position[0] - targetPoint[0]);
                const dy = Math.abs(position[1] - targetPoint[1]);
                const distance = Math.sqrt(dx * dx + dy * dy);
                
                return {
                    isAtPoint: distance < tolerance,
                    distance: distance,
                    exactMatch: dx < 0.01 && dy < 0.01
                };
            }

            // Медленное движение к точной цели
            moveToExactPosition(robot, targetPosition, options = {}) {
                const {
                    maxSpeed = robot.speed || 4.5,
                    minDistance = 0.01,
                    slowdownDistance = POSITION_CONFIG.SLOWDOWN_DISTANCE
                } = options;

                const dx = targetPosition[0] - robot.position[0];
                const dy = targetPosition[1] - robot.position[1];
                const distance = Math.sqrt(dx * dx + dy * dy);

                // Если уже достаточно близко
                if (distance < minDistance) {
                    robot.position[0] = targetPosition[0];
                    robot.position[1] = targetPosition[1];
                    return { reached: true, distance: 0 };
                }

                // Адаптивная скорость
                let speedFactor;
                if (distance > slowdownDistance) {
                    speedFactor = POSITION_CONFIG.NORMAL_SPEED;
                } else if (distance > 0.5) {
                    speedFactor = POSITION_CONFIG.SLOW_SPEED;
                } else {
                    speedFactor = POSITION_CONFIG.PRECISION_SPEED;
                }

                const speed = maxSpeed * speedFactor * 0.02;
                const ratio = Math.min(1, speed / distance);
                
                const moveX = dx * ratio;
                const moveY = dy * ratio;

                // Проверка столкновений с меньшим буфером для точного движения
                const newPosition = [
                    robot.position[0] + moveX,
                    robot.position[1] + moveY
                ];

                if (!this.controller.checkCollision(newPosition, 0.3)) {
                    robot.position[0] = newPosition[0];
                    robot.position[1] = newPosition[1];
                    
                    // Расход батареи пропорционально движению
                    const batteryConsumption = (robot.batteryConsumption || 0.02) * ratio;
                    robot.battery = Math.max(0, (robot.battery || 100) - batteryConsumption);
                    
                    const movement = Math.sqrt(moveX * moveX + moveY * moveY);
                    robot.totalDistance = (robot.totalDistance || 0) + movement;
                    
                    return { 
                        reached: false, 
                        distance: distance - movement,
                        movement: movement
                    };
                }

                return { reached: false, distance: distance, blocked: true };
            }

            // Коррекция позиции к точным координатам
            correctToExactPosition(robot, exactPosition) {
                const correction = {
                    dx: exactPosition[0] - robot.position[0],
                    dy: exactPosition[1] - robot.position[1],
                    distance: 0
                };
                
                correction.distance = Math.sqrt(correction.dx * correction.dx + correction.dy * correction.dy);
                
                // Если очень близко, просто устанавливаем точные координаты
                if (correction.distance < 0.1) {
                    robot.position[0] = exactPosition[0];
                    robot.position[1] = exactPosition[1];
                    return { corrected: true, distance: correction.distance };
                }
                
                return { corrected: false, distance: correction.distance };
            }
        }

        // ИСПРАВЛЕННЫЙ РЕЗЕРВНЫЙ КОНТРОЛЛЕР С УЧЕТОМ ЗАРЯДНЫХ МЕСТ
        function createFallbackController(factoryData) {
            return {
                data: factoryData,
                robots: [],
                orders: [],
                deliveryProgress: new Map(),
                cycleCount: 0,
                chargingRobots: new Map(),
                loadingRobots: new Map(),
                unloadingRobots: new Map(),
                shiftActive: true,
                totalDeliveries: 0,
                completedDeliveries: 0,
                pathfindingGrid: null,
                
                // ДИНАМИЧЕСКИЕ НАСТРОЙКИ БАТАРЕИ (настраиваемые через UI)
                BATTERY_CONFIG: {
                    EMERGENCY_THRESHOLD: 15,        // Экстренная зарядка (<15%)
                    PREVENTIVE_THRESHOLD: 25,       // Профилактическая зарядка (15-25%)
                    MIN_FOR_NEW_TASK: 20,           // Минимум для взятия нового задания
                    MIN_READY_THRESHOLD: 90,        // Минимум для статуса "готов"
                    TARGET_CHARGE: 100,             // Заряжаем до 100%
                    
                    // Время автономной работы (6 часов = 360 минут)
                    BATTERY_LIFE_MINUTES: 360,
                    
                    // Расчет оставшегося времени работы в минутах
                    getRemainingMinutes(batteryPercent) {
                        return Math.round((batteryPercent / 100) * this.BATTERY_LIFE_MINUTES);
                    },
                    
                    // Обновление настроек из UI
                    updateConfig(type, value) {
                        const numValue = parseInt(value);
                        if (!isNaN(numValue)) {
                            this[type] = numValue;
                            console.log(`⚡ Обновлена настройка ${type}: ${numValue}%`);
                            return true;
                        }
                        return false;
                    }
                },

                // НОВАЯ СИСТЕМА ТОЧНОГО ПОЗИЦИОНИРОВАНИЯ
                precision: null,
                
                // СЛОВАРЬ ТОЧЕК ДЛЯ ТОЧНОГО ПОЗИЦИОНИРОВАНИЯ
                exactPoints: {
                    charging: {},    // {pointId: coordinates}
                    loading: {},     // {pointId: coordinates}
                    unloading: {}    // {pointId: coordinates}
                },

                // Функция для нормализации названий типов роботов
                normalizeRobotType(robotType) {
                    const typeMap = {
                        'T-100': 'T-100',
                        'T-500': 'T-500', 
                        'T-1000': 'T-1000',
                        'Т-100 компакт': 'T-100',
                        'Т-500 универсал': 'T-500',
                        'Т-1000 Титан': 'T-1000'
                    };
                    return typeMap[robotType] || 'T-500';
                },
                
                // Проверяет, все ли задания выполнены или выполняются
                areAllDeliveriesAssigned() {
                    for (const [key, progress] of this.deliveryProgress) {
                        if (progress.completed) continue;
                        
                        // Если задание не выполнено и никем не выполняется
                        const isBeingProcessed = this.robots.some(robot => 
                            robot.currentDelivery === progress && 
                            robot.status !== 'ready' && 
                            robot.status !== 'charging'
                        );
                        
                        if (!isBeingProcessed) {
                            return false; // Найдено невыполняемое задание
                        }
                    }
                    return true; // Все задания выполняются
                },

                // Проверяет наличие полностью нераспределенных заданий
                hasUnassignedDeliveries() {
                    for (const [key, progress] of this.deliveryProgress) {
                        if (progress.completed) continue;
                        
                        // Если ни один робот не назначен на это задание
                        const isAssigned = this.robots.some(robot => 
                            robot.currentDelivery === progress
                        );
                        
                        if (!isAssigned) {
                            return true; // Найдено нераспределенное задание
                        }
                    }
                    return false;
                },
                
                // Проверяет, все ли задания выполнены (доставлено >= требуемого)
                areAllDeliveriesCompleted() {
                    for (const [key, progress] of this.deliveryProgress) {
                        if (!progress.completed && (progress.delivered || 0) < (progress.totalRequired || 0)) {
                            return false;
                        }
                    }
                    return true;
                },

                // УЛУЧШЕННАЯ система обнаружения застревания
                detectStuckRobot(robot) {
                    // НЕ считаем робота застрявшим если он готов или заряжается
                    if (robot.status === 'ready' || robot.status === 'charging') {
                        if (robot.stuckDetection?.isStuck) {
                            this.resetStuckState(robot);
                        }
                        return false;
                    }
                    
                    const now = Date.now();
                    
                    // Инициализация stuckDetection если нужно
                    if (!robot.stuckDetection) {
                        robot.stuckDetection = {
                            isStuck: false,
                            stuckStartTime: null,
                            positionHistory: [],
                            positionChangeThreshold: 1.0,
                            stuckTimeThreshold: 15000,
                            checkInterval: 2000,
                            lastCheckTime: now
                        };
                    }
                    
                    const sd = robot.stuckDetection;
                    
                    // Добавляем текущую позицию в историю
                    sd.positionHistory.push({
                        time: now,
                        x: robot.position[0],
                        y: robot.position[1]
                    });
                    
                    // Ограничиваем размер истории (последние 20 секунд)
                    const maxHistoryTime = 20000;
                    sd.positionHistory = sd.positionHistory.filter(point => 
                        now - point.time <= maxHistoryTime
                    );
                    
                    // Проверяем застревание только раз в checkInterval
                    if (now - sd.lastCheckTime < sd.checkInterval) {
                        return sd.isStuck;
                    }
                    sd.lastCheckTime = now;
                    
                    // Если робот на целевой точке - не считаем застрявшим
                    const isAtTargetPoint = 
                        robot.status === 'charging' || 
                        robot.status === 'loading' || 
                        robot.status === 'unloading' ||
                        (robot.targetPosition && this.calculateDistance(robot.position, robot.targetPosition) < 2.0);
                    
                    if (isAtTargetPoint) {
                        if (sd.isStuck) {
                            console.log(`🔄 Робот R${robot.id} достиг целевой точки, сбрасываю застревание`);
                            this.resetStuckState(robot);
                        }
                        return false;
                    }
                    
                    // Вычисляем общее перемещение за период
                    if (sd.positionHistory.length >= 2) {
                        const validHistory = sd.positionHistory.filter(point => 
                            now - point.time <= sd.stuckTimeThreshold
                        );
                        
                        if (validHistory.length >= 2) {
                            const oldestPoint = validHistory[0];
                            const totalDistance = this.calculateDistance(
                                [oldestPoint.x, oldestPoint.y],
                                robot.position
                            );
                            
                            const timeSpan = now - oldestPoint.time;
                            
                            // Если за период робот переместился меньше чем на порог
                            if (timeSpan >= sd.stuckTimeThreshold && totalDistance < sd.positionChangeThreshold) {
                                if (!sd.isStuck) {
                                    console.log(`🚨 Робот R${robot.id} ЗАСТРЯЛ! Перемещение: ${totalDistance.toFixed(2)}м за ${(timeSpan/1000).toFixed(1)}сек`);
                                    sd.isStuck = true;
                                    sd.stuckStartTime = now;
                                    
                                    // Пытаемся перестроить маршрут при застревании
                                    this.replanPath(robot);
                                }
                                return true;
                            } else {
                                // Робот двигается достаточно
                                if (sd.isStuck) {
                                    console.log(`🔄 Робот R${robot.id} снова двигается (${totalDistance.toFixed(2)}м за ${(timeSpan/1000).toFixed(1)}сек)`);
                                    this.resetStuckState(robot);
                                }
                                return false;
                            }
                        }
                    }
                    
                    return false;
                },
                
                // Сброс состояния застревания
                resetStuckState(robot) {
                    if (robot.stuckDetection) {
                        robot.stuckDetection.isStuck = false;
                        robot.stuckDetection.stuckStartTime = null;
                        robot.stuckDetection.stuckDuration = 0;
                        robot.stuckDetection.bufferReducedUntil = null;
                    }
                },

                // ИСПРАВЛЕННАЯ функция поиска доступного задания
                findAvailableDelivery(robot) {
                    const loadingPoints = this.data.loadingPoints || [];
                    let bestDelivery = null;
                    let bestPriority = -1;
                    let bestLoadingPoint = null;
                    let bestUnloadingPoint = null;
                    
                    // ПРОВЕРЯЕМ ВСЕ точки выгрузки и их требования
                    for (const [key, progress] of this.deliveryProgress) {
                        if (!progress.completed) {
                            // Ищем подходящую точку погрузки для этого типа груза
                            const suitableLoadingPoint = loadingPoints.find(lp => 
                                lp.cargoType === progress.cargoType
                            );
                            
                            if (suitableLoadingPoint) {
                                const unitWeight = suitableLoadingPoint.unitWeight || 50;
                                const robotCapacity = robot.carryingCapacity || 500;
                                
                                // ПРОВЕРЯЕМ, что робот может нести этот груз
                                if (robotCapacity >= unitWeight) {
                                    const unloadingPoint = this.data.unloadingPoints.find(up => 
                                        up.id === progress.unloadingPointId
                                    );
                                    
                                    if (unloadingPoint) {
                                        const priority = this.calculateDeliveryPriority(robot, progress, suitableLoadingPoint, unloadingPoint);
                                        
                                        if (priority > bestPriority) {
                                            bestPriority = priority;
                                            bestDelivery = progress;
                                            bestLoadingPoint = suitableLoadingPoint;
                                            bestUnloadingPoint = unloadingPoint;
                                        }
                                    }
                                }
                            }
                        }
                    }
                    
                    if (bestDelivery && bestLoadingPoint && bestUnloadingPoint) {
                        return {
                            progress: bestDelivery,
                            loadingPoint: bestLoadingPoint,
                            unloadingPoint: bestUnloadingPoint
                        };
                    }
                    
                    return null;
                },

                // ИСПРАВЛЕННАЯ функция создания заказа для доставки
                createOrderForDelivery(robot, deliveryInfo) {
                    if (!deliveryInfo || !deliveryInfo.loadingPoint || !deliveryInfo.unloadingPoint) {
                        console.warn('❌ Некорректные данные для создания заказа');
                        return null;
                    }

                    const { progress, loadingPoint, unloadingPoint } = deliveryInfo;
                    
                    const robotCapacity = robot.carryingCapacity || 500;
                    let unitWeight = loadingPoint.unitWeight || 50;
                    
                    // ЗАЩИТА от некорректных значений
                    if (unitWeight <= 0) {
                        console.warn(`❌ Некорректный вес единицы: ${unitWeight}, устанавливаю 50 по умолчанию`);
                        unitWeight = 50;
                    }
                    
                    const maxUnitsByCapacity = Math.floor(robotCapacity / unitWeight);
                    const maxUnitsByDelivery = Math.floor((progress.maxPerDelivery || 250) / unitWeight);
                    const remainingUnits = Math.ceil(((progress.totalRequired || 0) - (progress.delivered || 0)) / unitWeight);
                    
                    const unitsToLoad = Math.min(maxUnitsByCapacity, maxUnitsByDelivery, remainingUnits);
                    
                    if (unitsToLoad <= 0) {
                        console.warn(`❌ Не могу создать заказ: unitsToLoad = ${unitsToLoad}`);
                        return null;
                    }
                    
                    const weightToLoad = unitsToLoad * unitWeight;
                    
                    return {
                        id: `order_${robot.id}_${Date.now()}`,
                        cargoType: progress.cargoType,
                        source: loadingPoint.coordinates,
                        destination: unloadingPoint.coordinates,
                        status: 'pending',
                        loadingPointId: loadingPoint.id || `П${loadingPoint.coordinates[0]}_${loadingPoint.coordinates[1]}`,
                        unloadingPointId: unloadingPoint.id || `В${unloadingPoint.coordinates[0]}_${unloadingPoint.coordinates[1]}`,
                        units: unitsToLoad,
                        weight: weightToLoad,
                        progressKey: `${progress.unloadingPointId}_${progress.cargoType}`,
                        unitWeight: unitWeight
                    };
                },

                // ИСПРАВЛЕННЫЙ расчет приоритета доставки
                calculateDeliveryPriority(robot, progress, loadingPoint, unloadingPoint) {
                    if (!unloadingPoint) return 0;
                    
                    const distanceToLoading = this.calculateDistance(robot.position, loadingPoint.coordinates);
                    const distanceToUnloading = this.calculateDistance(loadingPoint.coordinates, unloadingPoint.coordinates);
                    const totalDistance = distanceToLoading + distanceToUnloading;
                    
                    const unitWeight = loadingPoint.unitWeight || 50;
                    const robotCapacity = robot.carryingCapacity || 500;
                    const optimalUnits = Math.floor(robotCapacity / unitWeight);
                    const requiredUnits = Math.ceil((progress.totalRequired - progress.delivered) / unitWeight);
                    
                    const capacityMatch = optimalUnits > 0 ? 1 - Math.abs(optimalUnits - requiredUnits) / optimalUnits : 0;
                    const remainingWork = progress.totalRequired - progress.delivered;
                    const priority = (remainingWork * capacityMatch) / (totalDistance + 1);
                    
                    return priority;
                },

                // ИСПРАВЛЕННАЯ проверка доступности точки зарядки для конкретного робота
                isChargingPointAvailableForRobot(point, robotId) {
                    const capacity = point.chargingPlaces || 1;
                    
                    // Считаем всех роботов, которые уже связаны с этой точкой (кроме текущего робота)
                    const connectedRobots = this.robots.filter(r => {
                        if (r.id === robotId) return false;
                        
                        // Робот заряжается на точке
                        if (r.status === 'charging') {
                            const distToPoint = this.calculateDistance(r.position, point.coordinates);
                            if (distToPoint < 1.5) return true;
                        }
                        
                        // Робот имеет эту точку в качестве цели зарядки
                        const pointId = point.id || `charge_${point.coordinates[0]}_${point.coordinates[1]}`;
                        return r.targetChargingPointId === pointId;
                    }).length;
                    
                    console.log(`🔋 Точка ${point.id || 'unknown'}: занято ${connectedRobots}/${capacity} мест`);
                    
                    return connectedRobots < capacity;
                },

                // УЛУЧШЕННАЯ логика назначения заданий с УЧЕТОМ БАТАРЕИ
                findAndAssignNextTask(robot) {
                    const remainingMinutes = this.BATTERY_CONFIG.getRemainingMinutes(robot.battery);
                    
                    // ВАЖНОЕ ИСПРАВЛЕНИЕ: Если робот уже заряжается или только что зарядился - НЕ ТРОГАЕМ!
                    if (robot.status === 'charging' || this.chargingRobots.has(robot.id)) {
                        console.log(`⏭️ Робот R${robot.id} уже заряжается, пропускаю поиск заданий`);
                        return;
                    }
                    
                    // Проверяем, не заряжался ли робот недавно (менее 15 секунд назад)
                    const timeSinceLastCharge = Date.now() - (robot.lastChargingEndTime || 0);
                    if (timeSinceLastCharge < 15000) { // 15 секунд
                        console.log(`⏭️ Робот R${robot.id} только что зарядился (${timeSinceLastCharge}мс назад), жду...`);
                        robot.status = 'ready';
                        robot.targetPosition = null;
                        robot.path = [];
                        return;
                    }
                    
                    // ВЫСШИЙ ПРИОРИТЕТ: Робот с грузом - всегда продолжает доставку
                    if (robot.cargo && robot.currentOrder) {
                        console.log(`📦 Робот R${robot.id} продолжает доставку груза ${robot.cargo.type} (заряд: ${robot.battery}%)`);
                        
                        if (robot.status !== 'moving_to_unload' && robot.status !== 'unloading') {
                            robot.status = 'moving_to_unload';
                            const pathToUnloading = this.findPath(robot.position, robot.currentOrder.destination);
                            if (pathToUnloading && pathToUnloading.length > 1) {
                                robot.path = pathToUnloading;
                                robot.currentPathIndex = 1;
                                robot.targetPosition = robot.path[robot.currentPathIndex];
                            } else {
                                robot.targetPosition = robot.currentOrder.destination;
                            }
                        }
                        return;
                    }
                    
                    // ПРИОРИТЕТ 2: Есть НЕРАСПРЕДЕЛЕННЫЕ задания и заряд позволяет
                    if (this.hasUnassignedDeliveries() && robot.battery > this.BATTERY_CONFIG.MIN_FOR_NEW_TASK) {
                        const deliveryInfo = this.findAvailableDelivery(robot);
                        if (deliveryInfo) {
                            robot.currentDelivery = deliveryInfo.progress;
                            const order = this.createOrderForDelivery(robot, deliveryInfo);
                            if (order) {
                                this.assignOrderToRobot(robot, order);
                                console.log(`🎯 Робот R${robot.id} взял задание (заряд: ${robot.battery}%)`);
                                return;
                            }
                        }
                    }
                    
                    // ПРИОРИТЕТ 3: Продолжаем текущее задание если есть (если заряд позволяет)
                    if (robot.currentDelivery && !robot.currentDelivery.completed && robot.battery > this.BATTERY_CONFIG.MIN_FOR_NEW_TASK) {
                        const deliveryInfo = this.findAvailableDelivery(robot);
                        if (deliveryInfo && deliveryInfo.progress === robot.currentDelivery) {
                            const order = this.createOrderForDelivery(robot, deliveryInfo);
                            if (order) {
                                this.assignOrderToRobot(robot, order);
                                return;
                            }
                        }
                    }
                    
                    // ПРИОРИТЕТ 4: КРИТИЧЕСКОЕ ИСПРАВЛЕНИЕ - не отправлять на зарядку, если только что зарядились
                    if (this.areAllDeliveriesCompleted()) {
                        // Если заряд выше порога готовности - остаемся в ready
                        if (robot.battery >= this.BATTERY_CONFIG.MIN_READY_THRESHOLD) {
                            console.log(`🟢 Робот R${robot.id}: задания выполнены, заряд ${robot.battery}% ≥ ${this.BATTERY_CONFIG.MIN_READY_THRESHOLD}%, остаюсь в ready`);
                            robot.status = 'ready';
                            robot.targetPosition = null;
                            robot.path = [];
                            return;
                        } else {
                            // Заряд ниже порога - едем на зарядку
                            console.log(`🔋 Робот R${robot.id}: задания выполнены, заряд ${robot.battery}% < ${this.BATTERY_CONFIG.MIN_READY_THRESHOLD}%, еду на зарядку`);
                            this.sendToOptimalChargingPoint(robot);
                            return;
                        }
                    }
                    
                    // ПРИОРИТЕТ 5: Экстренная зарядка для роботов без груза
                    if (robot.battery < this.BATTERY_CONFIG.EMERGENCY_THRESHOLD && !robot.cargo) {
                        console.log(`🔋 Робот R${robot.id}: экстренная зарядка (${robot.battery}%)`);
                        this.sendToOptimalChargingPoint(robot);
                        return;
                    }
                    
                    // ПРИОРИТЕТ 6: Профилактическая зарядка для роботов без груза (если нет срочных заданий)
                    if (robot.battery < this.BATTERY_CONFIG.PREVENTIVE_THRESHOLD && !this.hasUnassignedDeliveries() && !robot.cargo) {
                        console.log(`🔋 Робот R${robot.id}: профилактическая зарядка (${robot.battery}%)`);
                        this.sendToOptimalChargingPoint(robot);
                        return;
                    }
                    
                    // ПРИОРИТЕТ 7: Если есть задания, но все распределены - ждем своей очереди
                    console.log(`⏳ Робот R${robot.id} ждет задания (заряд: ${robot.battery}%)`);
                    robot.status = 'ready';
                    robot.targetPosition = null;
                    robot.path = [];
                },

                // ДОБАВИТЬ отладочную информацию в функцию назначения заказа
                assignOrderToRobot(robot, order) {
                    try {
                        if (!order || !order.source || !order.destination) {
                            console.error(`❌ Некорректный заказ для робота R${robot.id}`, order);
                            return;
                        }
                        
                        order.status = 'in_progress';
                        robot.currentOrder = order;
                        
                        console.log(`🤖 Робот R${robot.id} (${robot.type}) получил задание: ${order.loadingPointId}→${order.unloadingPointId}`);
                        
                        // СБРАСЫВАЕМ флаги при начале нового задания
                        robot.isAtTargetPoint = false;
                        robot.lastTargetType = null;
                        robot.targetReachedTime = null;
                        
                        const pathToLoading = this.findPath(robot.position, order.source);
                        if (pathToLoading && pathToLoading.length > 1) {
                            robot.path = pathToLoading;
                            robot.currentPathIndex = 1;
                            robot.targetPosition = robot.path[robot.currentPathIndex];
                            robot.status = 'moving_to_load';
                            robot.failedPathAttempts = 0;
                            console.log(`🗺️ Робот R${robot.id} построил путь из ${pathToLoading.length} точек`);
                        } else {
                            robot.targetPosition = order.source;
                            robot.status = 'moving_to_load';
                            console.log(`➡️ Робот R${robot.id} движется напрямую к цели`);
                        }
                    } catch (error) {
                        console.error('Ошибка назначения заказа:', error);
                    }
                },

                // УЛУЧШЕННАЯ функция движения по пути с ИСПРАВЛЕНИЕМ для распознавания достижения цели
                followPath(robot) {
                    if (!robot.path || robot.currentPathIndex >= robot.path.length) {
                        console.warn(`❌ У робота R${robot.id} некорректный путь`);
                        this.findNewTarget(robot);
                        return;
                    }
                    
                    const currentTarget = robot.path[robot.currentPathIndex];
                    const dx = currentTarget[0] - robot.position[0];
                    const dy = currentTarget[1] - robot.position[1];
                    const distance = Math.sqrt(dx * dx + dy * dy);
                    
                    if (distance < 0.5) {
                        robot.currentPathIndex++;
                        
                        if (robot.currentPathIndex < robot.path.length) {
                            robot.targetPosition = robot.path[robot.currentPathIndex];
                            console.log(`🔄 Робот R${robot.id} достиг промежуточной точки, следующая: ${robot.currentPathIndex}/${robot.path.length}`);
                        } else {
                            console.log(`🎯 Робот R${robot.id} завершил путь`);
                            robot.path = [];
                            robot.currentPathIndex = 0;
                            // ИСПРАВЛЕНИЕ: Вместо findNewTarget вызываем handleDestinationReached
                            this.handleDestinationReached(robot);
                        }
                    } else {
                        const robotSpeed = robot.speed || 4.5;
                        const speed = robotSpeed * 0.05;
                        const ratio = Math.min(1, speed / distance);
                        
                        const moveX = dx * ratio;
                        const moveY = dy * ratio;
                        
                        const newPosition = [robot.position[0] + moveX, robot.position[1] + moveY];
                        
                        // ПРОВЕРКА столкновений с запасом
                        if (!this.checkCollision(newPosition, 1.5)) {
                            robot.position[0] = newPosition[0];
                            robot.position[1] = newPosition[1];
                            robot.lastMovementTime = Date.now();
                        } else {
                            robot.failedPathAttempts++;
                            console.warn(`🚧 Робот R${robot.id} столкнулся с препятствием, попытка ${robot.failedPathAttempts}`);
                            
                            if (robot.failedPathAttempts > 3) {
                                this.replanPath(robot);
                            }
                        }
                        
                        // РАСХОД батареи
                        const batteryConsumption = robot.batteryConsumption || 0.02;
                        robot.battery = Math.max(0, (robot.battery || 100) - batteryConsumption);
                        robot.totalDistance = (robot.totalDistance || 0) + Math.sqrt(moveX * moveX + moveY * moveY);
                    }
                },

                // ИСПРАВЛЕННЫЙ метод moveDirectlyToTarget
                moveDirectlyToTarget(robot) {
                    const dx = robot.targetPosition[0] - robot.position[0];
                    const dy = robot.targetPosition[1] - robot.position[1];
                    const distance = Math.sqrt(dx * dx + dy * dy);
                    
                    if (distance < 0.5) {
                        this.handleDestinationReached(robot);
                    } else {
                        const robotSpeed = robot.speed || 4.5;
                        const speed = robotSpeed * 0.02;
                        const ratio = speed / distance;
                        
                        const moveX = dx * ratio;
                        const moveY = dy * ratio;
                        
                        const newPosition = [robot.position[0] + moveX, robot.position[1] + moveY];
                        if (!this.checkCollision(newPosition)) {
                            robot.position[0] = newPosition[0];
                            robot.position[1] = newPosition[1];
                        } else {
                            robot.failedPathAttempts++;
                            if (robot.failedPathAttempts <= 3) {
                                this.findAlternativePath(robot);
                            } else {
                                this.replanPath(robot);
                            }
                        }
                        
                        const batteryConsumption = robot.batteryConsumption || 0.02;
                        robot.battery = Math.max(0, (robot.battery || 100) - batteryConsumption);
                        robot.totalDistance = (robot.totalDistance || 0) + Math.sqrt(moveX * moveX + moveY * moveY);
                    }
                },

                // УЛУЧШЕННАЯ логика движения с проверкой батареи - ИСПРАВЛЕННАЯ ВЕРСИЯ
                updateSingleRobot(robot) {
                    // ПРОВЕРКА ЭКСТРЕННОЙ ЗАРЯДКИ ТОЛЬКО ДЛЯ РОБОТОВ БЕЗ ГРУЗА
                    if (robot.battery < this.BATTERY_CONFIG.EMERGENCY_THRESHOLD && 
                        !robot.cargo && 
                        robot.status !== 'charging' && 
                        robot.status !== 'ready' &&
                        robot.status !== 'moving_to_unload' &&
                        robot.status !== 'unloading') {
                        console.log(`🆘 Робот R${robot.id} имеет низкий заряд (${robot.battery}%), экстренная зарядка`);
                        this.handleLowBatteryEmergency(robot);
                        return;
                    }
                    
                    // Проверяем застревание
                    this.detectStuckRobot(robot);
                    
                    // ОБРАБОТКА ПО СОСТОЯНИЮ
                    switch (robot.status) {
                        case 'moving_to_load':
                        case 'moving_to_unload':
                        case 'moving_to_charge':
                            this.updateRobotMovement(robot);
                            break;
                            
                        case 'loading':
                        case 'unloading':
                            // Эти статусы обрабатываются в updateLoadingUnloading()
                            // Не нужно здесь ничего делать, просто продолжаем
                            break;
                            
                        case 'charging':
                            // В процессе зарядки НЕ прерываемся - заряжаемся до 100%
                            // Обновление заряда происходит в updateCharging()
                            break;
                            
                        case 'ready':
                            // ⭐ ИСПРАВЛЕНИЕ: Робот "готов" если заряд выше MIN_READY_THRESHOLD (90%)
                            if (robot.battery < this.BATTERY_CONFIG.MIN_READY_THRESHOLD) {
                                console.warn(`⚠️ Робот R${robot.id} в статусе ready, но заряд ${robot.battery}% < ${this.BATTERY_CONFIG.MIN_READY_THRESHOLD}% - отправляю на зарядку`);
                                this.sendToOptimalChargingPoint(robot);
                            } else {
                                // Если заряд достаточный - ищем задание
                                this.findAndAssignNextTask(robot);
                            }
                            break;
                    }
                },

                // Обновление движения робота - ИСПРАВЛЕННАЯ ВЕРСИЯ
                updateRobotMovement(robot) {
                    // СНАЧАЛА проверяем, не достигли ли мы уже цели
                    if (robot.targetPosition && this.checkIfAtTarget(robot)) {
                        console.log(`🎯 Робот R${robot.id} уже на целевой точке!`);
                        this.handleDestinationReached(robot);
                        return;
                    }
                    
                    if (!robot.targetPosition) {
                        console.log(`❌ Робот R${robot.id} не имеет целевой позиции при статусе ${robot.status}`);
                        this.findNewTarget(robot);
                        return;
                    }
                    
                    const distance = this.calculateDistance(robot.position, robot.targetPosition);
                    
                    if (distance < 0.5) {
                        console.log(`✅ Робот R${robot.id} достиг цели`);
                        this.handleDestinationReached(robot);
                        return;
                    }
                    
                    if (robot.path && robot.path.length > 0 && robot.currentPathIndex < robot.path.length) {
                        this.followPath(robot);
                    } else {
                        this.moveDirectlyToTarget(robot);
                    }
                },

                // ИСПРАВЛЕННЫЙ метод findNewTarget
                findNewTarget(robot) {
                    console.log(`🔍 Робот R${robot.id} ищет новую цель. Статус: ${robot.status}`);
                    
                    // Проверяем, не достигли ли мы уже точки погрузки/выгрузки
                    if (robot.currentOrder) {
                        const distanceToSource = this.calculateDistance(robot.position, robot.currentOrder.source);
                        const distanceToDestination = this.calculateDistance(robot.position, robot.currentOrder.destination);
                        
                        // Если уже на точке погрузки и статус moving_to_load
                        if (distanceToSource < 2.0 && robot.status === 'moving_to_load') {
                            console.log(`📦 Робот R${robot.id} уже на точке погрузки! Переключаю на погрузку...`);
                            this.handleDestinationReached(robot);
                            return;
                        }
                        
                        // Если уже на точке выгрузки и статус moving_to_unload
                        if (distanceToDestination < 2.0 && robot.status === 'moving_to_unload' && robot.cargo) {
                            console.log(`📤 Робот R${robot.id} уже на точке выгрузки! Переключаю на выгрузку...`);
                            this.handleDestinationReached(robot);
                            return;
                        }
                    }
                    
                    // Если статус ready - ищем задание
                    if (robot.status === 'ready') {
                        this.findAndAssignNextTask(robot);
                    } else if (robot.status === 'loading') {
                        // Уже на точке погрузки - ничего не делаем
                        console.log(`📦 Робот R${robot.id} уже на точке погрузки, жду завершения...`);
                    } else if (robot.status === 'unloading') {
                        // Уже на точке выгрузки - ничего не делаем
                        console.log(`📤 Робот R${robot.id} уже на точке выгрузки, жду завершения...`);
                    } else if (robot.status === 'moving_to_charge') {
                        // Ищем новую точку зарядки
                        this.sendToOptimalChargingPoint(robot);
                    } else if (robot.currentOrder) {
                        // Если есть заказ, продолжаем его выполнение
                        if (robot.status === 'moving_to_load') {
                            robot.targetPosition = robot.currentOrder.source;
                            console.log(`➡️ Робот R${robot.id} продолжаю движение к погрузке`);
                        } else if (robot.status === 'moving_to_unload') {
                            robot.targetPosition = robot.currentOrder.destination;
                            console.log(`➡️ Робот R${robot.id} продолжаю движение к выгрузке`);
                        }
                    } else {
                        // Если ничего не подошло - готов
                        console.log(`🔄 Робот R${robot.id} не имеет заданий, перевожу в ready`);
                        robot.status = 'ready';
                        robot.targetPosition = null;
                        robot.path = [];
                    }
                },

                // Упрощенная экстренная зарядка (только для роботов без груза)
                handleLowBatteryEmergency(robot) {
                    console.log(`🆘 Робот R${robot.id} имеет низкий заряд (${robot.battery}%), экстренная зарядка`);
                    
                    // УБЕЖДАЕМСЯ, что у робота НЕТ груза
                    if (robot.cargo) {
                        console.error(`❌ КРИТИЧЕСКАЯ ОШИБКА: Робот R${robot.id} с грузом ${robot.cargo.type} не должен вызывать экстренную зарядку!`);
                        return;
                    }
                    
                    // Отменяем текущее задание только если нет груза
                    if (robot.currentOrder) {
                        console.log(`❌ Робот R${robot.id} отменяет задание для экстренной зарядки`);
                        robot.currentOrder = null;
                        robot.currentDelivery = null;
                    }
                    
                    // Сбрасываем груз (на всякий случай)
                    robot.cargo = null;
                    
                    // Сбрасываем флаги
                    robot.isAtTargetPoint = false;
                    robot.lastTargetType = null;
                    robot.targetReachedTime = null;
                    
                    // Отправляем на зарядку
                    this.sendToOptimalChargingPoint(robot);
                },

                // ИНИЦИАЛИЗАЦИЯ ТОЧНЫХ ТОЧЕК
                initializeExactPoints() {
                    // Точки зарядки
                    (this.data.chargingPoints || []).forEach(point => {
                        if (point.coordinates && point.coordinates.length === 2) {
                            this.exactPoints.charging[point.id || `charge_${point.coordinates[0]}_${point.coordinates[1]}`] = 
                                [...point.coordinates];
                        }
                    });
                    
                    // Точки погрузки
                    (this.data.loadingPoints || []).forEach(point => {
                        if (point.coordinates && point.coordinates.length === 2) {
                            this.exactPoints.loading[point.id || `load_${point.coordinates[0]}_${point.coordinates[1]}`] = 
                                [...point.coordinates];
                        }
                    });
                    
                    // Точки выгрузки
                    (this.data.unloadingPoints || []).forEach(point => {
                        if (point.coordinates && point.coordinates.length === 2) {
                            this.exactPoints.unloading[point.id || `unload_${point.coordinates[0]}_${point.coordinates[1]}`] = 
                                [...point.coordinates];
                        }
                    });
                    
                    console.log('🎯 Инициализированы точные точки:', {
                        charging: Object.keys(this.exactPoints.charging).length,
                        loading: Object.keys(this.exactPoints.loading).length,
                        unloading: Object.keys(this.exactPoints.unloading).length
                    });
                },
                
                // ПОИСК БЛИЖАЙШЕЙ ТОЧНОЙ ТОЧКИ
                findNearestExactPoint(position, pointType, maxDistance = 5.0) {
                    const points = this.exactPoints[pointType];
                    if (!points) return null;
                    
                    let nearestPoint = null;
                    let minDistance = Infinity;
                    let pointId = null;
                    
                    for (const [id, coords] of Object.entries(points)) {
                        const distance = this.calculateDistance(position, coords);
                        if (distance < minDistance && distance < maxDistance) {
                            minDistance = distance;
                            nearestPoint = coords;
                            pointId = id;
                        }
                    }
                    
                    return nearestPoint ? {
                        coordinates: nearestPoint,
                        id: pointId,
                        distance: minDistance
                    } : null;
                },
                
                // ПРОВЕРКА ТОЧНОГО НАХОЖДЕНИЯ НА ТОЧКЕ
                isAtExactPointType(position, pointType, tolerance = 0.1) {
                    const nearest = this.findNearestExactPoint(position, pointType, tolerance * 2);
                    if (!nearest) return null;
                    
                    const check = this.precision.isAtExactPoint(position, nearest.coordinates, tolerance);
                    if (check.isAtPoint) {
                        return {
                            pointId: nearest.id,
                            coordinates: nearest.coordinates,
                            distance: check.distance,
                            exactMatch: check.exactMatch
                        };
                    }
                    return null;
                },

                // ИСПРАВЛЕННАЯ функция поиска ближайшей доступной точки зарядки
                findNearestAvailableChargingPoint(robot) {
                    const chargingPoints = this.data.chargingPoints || [];
                    if (chargingPoints.length === 0) {
                        return {
                            coordinates: [5, 5],
                            id: 'default',
                            chargingPlaces: 1
                        };
                    }
                    
                    // Сортируем точки по расстоянию от робота
                    const pointsWithDistance = chargingPoints.map(point => {
                        const distance = this.calculateDistance(robot.position, point.coordinates);
                        return {
                            point: point,
                            distance: distance
                        };
                    }).sort((a, b) => a.distance - b.distance);
                    
                    // Ищем ближайшую точку, где есть свободные места
                    for (const { point, distance } of pointsWithDistance) {
                        if (!point.coordinates || !Array.isArray(point.coordinates)) {
                            console.warn(`❌ Некорректная точка зарядки:`, point);
                            continue;
                        }
                        
                        const capacity = point.chargingPlaces || 1;
                        const pointId = point.id || `charge_${point.coordinates[0]}_${point.coordinates[1]}`;
                        
                        // Считаем сколько роботов уже "привязано" к этой точке
                        const connectedRobots = this.robots.filter(r => {
                            if (r.id === robot.id) return false;
                            
                            // Роботы, которые уже заряжаются на точке
                            if (r.status === 'charging') {
                                const distToPoint = this.calculateDistance(r.position, point.coordinates);
                                if (distToPoint < 1.5) return true;
                            }
                            
                            // Роботы, которые движутся к точке или забронировали ее
                            return r.targetChargingPointId === pointId;
                        }).length;
                        
                        // ВАЖНОЕ ИСПРАВЛЕНИЕ: точка доступна если connectedRobots < capacity
                        // Это позволяет нескольким роботам выбрать одну точку
                        if (connectedRobots < capacity) {
                            console.log(`✅ Точка ${pointId}: ${connectedRobots}/${capacity} мест занято - ДОСТУПНА`);
                            return {
                                coordinates: [...point.coordinates],
                                id: pointId,
                                chargingPlaces: capacity,
                                distance: distance,
                                freeSpaces: capacity - connectedRobots
                            };
                        } else {
                            console.log(`❌ Точка ${pointId}: ${connectedRobots}/${capacity} мест занято - ЗАНЯТА`);
                        }
                    }
                    
                    // Если ни одна точка не доступна, ищем наименее загруженную
                    return this.findLeastLoadedChargingPoint(robot);
                },

                // НОВАЯ ФУНКЦИЯ: Поиск точки зарядки с наименьшей загруженностью
                findLeastLoadedChargingPoint(robot) {
                    const chargingPoints = this.data.chargingPoints || [];
                    if (chargingPoints.length === 0) {
                        return {
                            coordinates: [5, 5],
                            id: 'default',
                            chargingPlaces: 1
                        };
                    }
                    
                    let bestPoint = null;
                    let bestLoadRatio = Infinity;
                    let bestDistance = Infinity;
                    
                    chargingPoints.forEach(point => {
                        if (!point.coordinates || !Array.isArray(point.coordinates)) return;
                        
                        const capacity = point.chargingPlaces || 1;
                        const pointId = point.id || `charge_${point.coordinates[0]}_${point.coordinates[1]}`;
                        const distance = this.calculateDistance(robot.position, point.coordinates);
                        
                        // Считаем connectedRobots так же, как в findNearestAvailableChargingPoint
                        const connectedRobots = this.robots.filter(r => {
                            if (r.id === robot.id) return false;
                            
                            // Роботы, которые уже заряжаются на точке
                            if (r.status === 'charging') {
                                const distToPoint = this.calculateDistance(r.position, point.coordinates);
                                if (distToPoint < 1.5) return true;
                            }
                            
                            // Роботы, которые движутся к точке или забронировали ее
                            return r.targetChargingPointId === pointId;
                        }).length;
                        
                        const loadRatio = connectedRobots / capacity;
                        
                        if (loadRatio < bestLoadRatio || 
                            (Math.abs(loadRatio - bestLoadRatio) < 0.01 && distance < bestDistance)) {
                            bestLoadRatio = loadRatio;
                            bestDistance = distance;
                            const pointId = point.id || `charge_${point.coordinates[0]}_${point.coordinates[1]}`;
                            bestPoint = {
                                coordinates: [...point.coordinates],
                                id: pointId,
                                chargingPlaces: capacity,
                                distance: distance,
                                loadRatio: loadRatio
                            };
                        }
                    });
                    
                    if (bestPoint) {
                        console.log(`🔋 Робот R${robot.id} выбрал наименее загруженную точку ${bestPoint.id} (загрузка: ${(bestPoint.loadRatio * 100).toFixed(0)}%)`);
                        return bestPoint;
                    }
                    
                    // Если не нашли (маловероятно), возвращаем первую точку
                    const firstPoint = chargingPoints[0];
                    const pointId = firstPoint.id || `charge_${firstPoint.coordinates[0]}_${firstPoint.coordinates[1]}`;
                    return {
                        coordinates: [...firstPoint.coordinates],
                        id: pointId,
                        chargingPlaces: firstPoint.chargingPlaces || 1
                    };
                },

                // УЛУЧШЕННЫЙ МЕТОД ДЛЯ ТОЧНОГО ПОЗИЦИОНИРОВАНИЯ - ИСПРАВЛЕННАЯ ВЕРСИЯ
                sendToOptimalChargingPoint(robot) {
                    console.log(`\n🔋 === ПОИСК ТОЧКИ ЗАРЯДКИ ДЛЯ R${robot.id} ===`);
                    
                    // Выводим информацию обо всех точках зарядки
                    if (this.data.chargingPoints) {
                        this.data.chargingPoints.forEach(point => {
                            const capacity = point.chargingPlaces || 1;
                            const pointId = point.id || `charge_${point.coordinates[0]}_${point.coordinates[1]}`;
                            
                            // Считаем всех роботов, связанных с этой точкой
                            const connectedRobots = this.robots.filter(r => {
                                if (r.id === robot.id) return false;
                                
                                // Роботы, которые уже заряжаются на точке
                                if (r.status === 'charging') {
                                    const distToPoint = this.calculateDistance(r.position, point.coordinates);
                                    if (distToPoint < 1.5) return true;
                                }
                                
                                // Роботы, которые имеют эту точку в качестве цели
                                return r.targetChargingPointId === pointId;
                            }).length;
                            
                            console.log(`   Точка ${pointId}: ${connectedRobots}/${capacity}`);
                        });
                    }
                    
                    // Защита от повторных вызовов
                    if (robot.status === 'charging' || robot.status === 'moving_to_charge') {
                        console.log(`⏭️ Робот R${robot.id} уже заряжается или едет на зарядку`);
                        return;
                    }
                    
                    // Отменяем предыдущее бронирование
                    if (robot.targetChargingPointId) {
                        console.log(`🔄 Робот R${robot.id} отменяет предыдущую бронь точки ${robot.targetChargingPointId}`);
                        robot.targetChargingPointId = null;
                    }
                    
                    // Инициализируем систему точного позиционирования если нужно
                    if (!this.precision) {
                        this.precision = new PrecisionPositioning(this);
                        this.initializeExactPoints();
                    }
                    
                    // 1. Проверяем, не находимся ли мы УЖЕ точно на точке зарядки
                    const exactChargingPoint = this.isAtExactPointType(
                        robot.position, 
                        'charging', 
                        POSITION_CONFIG.CHARGING_TOLERANCE
                    );
                    
                    if (exactChargingPoint && (robot.status === 'moving_to_charge' || robot.status === 'ready')) {
                        console.log(`✅ Робот R${robot.id} УЖЕ точно на точке зарядки ${exactChargingPoint.pointId}`);
                        
                        if (robot.status === 'charging' || this.chargingRobots.has(robot.id)) {
                            console.log(`⏭️ Уже заряжается, пропускаю`);
                            return;
                        }
                        
                        this.handleChargingDestinationReachedExact(robot, exactChargingPoint);
                        return;
                    }
                    
                    // 2. Отменяем задания если нужно
                    if (robot.currentOrder && !robot.cargo) {
                        console.log(`❌ Отменяю задание для зарядки`);
                        robot.currentOrder = null;
                        robot.currentDelivery = null;
                    }
                    
                    // 3. Ищем ближайшую доступную точку
                    const chargingPoint = this.findNearestAvailableChargingPoint(robot);
                    
                    // ЗАЩИТА: Проверяем структуру возвращаемого объекта
                    if (!chargingPoint || !chargingPoint.coordinates || !Array.isArray(chargingPoint.coordinates)) {
                        console.error(`❌ Некорректная точка зарядки для робота R${robot.id}:`, chargingPoint);
                        
                        // Используем точку по умолчанию
                        const defaultPoint = {
                            coordinates: [5, 5],
                            id: 'default',
                            chargingPlaces: 1
                        };
                        
                        robot.targetPosition = defaultPoint.coordinates;
                        robot.status = 'moving_to_charge';
                        robot.exactTarget = defaultPoint.coordinates;
                        robot.targetChargingPointId = defaultPoint.id;
                        console.log(`➡️ Робот R${robot.id} движется к точке зарядки по умолчанию [5, 5]`);
                        return;
                    }
                    
                    // 4. Запоминаем "свою" точку
                    robot.targetChargingPointId = chargingPoint.id;
                    robot.lastChargingPoint = [...chargingPoint.coordinates];
                    
                    console.log(`✅ Робот R${robot.id} забронировал точку ${chargingPoint.id} (${chargingPoint.chargingPlaces} мест, свободно: ${chargingPoint.freeSpaces || 0})`);
                    
                    // 5. Строим путь к ТОЧНЫМ координатам
                    const exactTarget = chargingPoint.coordinates;
                    
                    // Проверяем расстояние
                    const distance = this.calculateDistance(robot.position, exactTarget);
                    console.log(`📏 Расстояние до точки З${chargingPoint.id}: ${distance.toFixed(2)}м`);
                    
                    if (distance < POSITION_CONFIG.CHARGING_TOLERANCE) {
                        // Уже почти на точке - точное позиционирование
                        console.log(`🎯 Почти на точке, точное позиционирование`);
                        const correction = this.precision.correctToExactPosition(robot, exactTarget);
                        if (correction.corrected) {
                            console.log(`🎯 Робот R${robot.id} скорректирован к точным координатам`);
                        }
                        this.handleChargingDestinationReachedExact(robot, {
                            coordinates: exactTarget,
                            pointId: chargingPoint.id,
                            distance: distance
                        });
                        return;
                    }
                    
                    // Строим путь с конечной точкой РОВНО на координатах зарядки
                    const path = this.findPathWithExactTarget(robot.position, exactTarget);
                    if (path && path.length > 1) {
                        // Последняя точка пути ДОЛЖНА быть точно на координатах зарядки
                        path[path.length - 1] = [...exactTarget];
                        
                        robot.path = path;
                        robot.currentPathIndex = 1;
                        robot.targetPosition = robot.path[robot.currentPathIndex];
                        robot.status = 'moving_to_charge';
                        robot.exactTarget = exactTarget; // Сохраняем точные координаты цели
                        
                        console.log(`🗺️ Построен путь из ${path.length} точек к З${chargingPoint.id}`);
                    } else {
                        // Прямое движение к точным координатам
                        robot.targetPosition = exactTarget;
                        robot.status = 'moving_to_charge';
                        robot.exactTarget = exactTarget;
                        console.log(`➡️ Прямое движение к З${chargingPoint.id}`);
                    }
                },
                
                // НОВАЯ ФУНКЦИЯ: Умное распределение роботов по точкам зарядки
                distributeRobotsToChargingPoints(robotsNeedingCharge) {
                    if (robotsNeedingCharge.length === 0) return;
                    
                    const chargingPoints = this.data.chargingPoints || [];
                    
                    // Создаем карту доступности точек зарядки
                    const pointAvailability = chargingPoints.map(point => {
                        const capacity = point.chargingPlaces || 1;
                        const pointId = point.id || `charge_${point.coordinates[0]}_${point.coordinates[1]}`;
                        
                        // Считаем занятые места
                        const occupied = this.robots.filter(r => {
                            // Роботы на зарядке
                            if (r.status === 'charging') {
                                const dist = this.calculateDistance(r.position, point.coordinates);
                                return dist < 1.5;
                            }
                            
                            // Роботы, которые едут или забронировали
                            return r.targetChargingPointId === pointId;
                        }).length;
                        
                        return {
                            point: point,
                            id: pointId,
                            capacity: capacity,
                            occupied: occupied,
                            free: capacity - occupied,
                            distanceFromCenter: 0 // рассчитаем ниже
                        };
                    }).filter(p => p.free > 0); // Только точки со свободными местами
                    
                    if (pointAvailability.length === 0) return;
                    
                    // Рассчитываем "центр массы" роботов, которым нужна зарядка
                    const centerX = robotsNeedingCharge.reduce((sum, r) => sum + r.position[0], 0) / robotsNeedingCharge.length;
                    const centerY = robotsNeedingCharge.reduce((sum, r) => sum + r.position[1], 0) / robotsNeedingCharge.length;
                    
                    // Расстояние от центра до каждой точки зарядки
                    pointAvailability.forEach(p => {
                        p.distanceFromCenter = this.calculateDistance([centerX, centerY], p.point.coordinates);
                    });
                    
                    // Сортируем точки: сначала ближайшие к центру, потом с большим количеством свободных мест
                    pointAvailability.sort((a, b) => {
                        if (a.distanceFromCenter !== b.distanceFromCenter) {
                            return a.distanceFromCenter - b.distanceFromCenter;
                        }
                        return b.free - a.free; // больше свободных мест -> приоритетнее
                    });
                    
                    // Распределяем роботов по точкам
                    let robotIndex = 0;
                    for (const pointInfo of pointAvailability) {
                        // Сколько роботов можно отправить на эту точку
                        const robotsForThisPoint = Math.min(pointInfo.free, robotsNeedingCharge.length - robotIndex);
                        
                        for (let i = 0; i < robotsForThisPoint; i++) {
                            const robot = robotsNeedingCharge[robotIndex];
                            
                            // Сбрасываем предыдущую бронь
                            if (robot.targetChargingPointId) {
                                console.log(`🔄 Робот R${robot.id} освобождает точку ${robot.targetChargingPointId}`);
                                robot.targetChargingPointId = null;
                            }
                            
                            // Бронируем новую точку
                            robot.targetChargingPointId = pointInfo.id;
                            robot.lastChargingPoint = [...pointInfo.point.coordinates];
                            
                            console.log(`🎯 Робот R${robot.id} назначен на точку ${pointInfo.id} (свободно мест: ${pointInfo.free - i - 1})`);
                            
                            // Отправляем робота на точку
                            this.sendRobotToChargingPoint(robot, pointInfo.point);
                            
                            robotIndex++;
                            
                            if (robotIndex >= robotsNeedingCharge.length) return;
                        }
                    }
                },
                
                // Вспомогательный метод для отправки робота на конкретную точку
                sendRobotToChargingPoint(robot, point) {
                    const pointId = point.id || `charge_${point.coordinates[0]}_${point.coordinates[1]}`;
                    const exactTarget = [...point.coordinates];
                    
                    robot.targetChargingPointId = pointId;
                    robot.lastChargingPoint = exactTarget;
                    
                    const distance = this.calculateDistance(robot.position, exactTarget);
                    console.log(`📏 Робот R${robot.id} -> ${pointId}: ${distance.toFixed(2)}м`);
                    
                    if (distance < POSITION_CONFIG.CHARGING_TOLERANCE) {
                        // Уже почти на точке
                        this.handleChargingDestinationReachedExact(robot, {
                            coordinates: exactTarget,
                            pointId: pointId,
                            distance: distance
                        });
                        return;
                    }
                    
                    // Строим путь
                    const path = this.findPathWithExactTarget(robot.position, exactTarget);
                    if (path && path.length > 1) {
                        path[path.length - 1] = [...exactTarget];
                        robot.path = path;
                        robot.currentPathIndex = 1;
                        robot.targetPosition = robot.path[robot.currentPathIndex];
                        robot.status = 'moving_to_charge';
                        robot.exactTarget = exactTarget;
                        console.log(`🗺️ Робот R${robot.id} построил путь из ${path.length} точек к ${pointId}`);
                    } else {
                        robot.targetPosition = exactTarget;
                        robot.status = 'moving_to_charge';
                        robot.exactTarget = exactTarget;
                        console.log(`➡️ Робот R${robot.id} прямой путь к ${pointId}`);
                    }
                },
                
                // НОВЫЙ МЕТОД: Поиск пути с гарантией точного финиша
                findPathWithExactTarget(start, exactTarget) {
                    try {
                        // Сначала ищем обычный путь
                        const path = this.findPath(start, exactTarget);
                        
                        if (!path || path.length === 0) {
                            return [start, exactTarget];
                        }
                        
                        // Гарантируем, что последняя точка РОВНО на цели
                        path[path.length - 1] = [...exactTarget];
                        
                        // Добавляем промежуточные точки для точности на последнем участке
                        if (path.length >= 2) {
                            const lastSegmentStart = path[path.length - 2];
                            const lastSegmentEnd = path[path.length - 1];
                            const segmentDistance = this.calculateDistance(lastSegmentStart, lastSegmentEnd);
                            
                            // Если последний сегмент длинный, добавляем промежуточные точки
                            if (segmentDistance > 2.0) {
                                const pointsToAdd = Math.floor(segmentDistance / 1.0); // Точки каждые 1 метр
                                for (let i = 1; i <= pointsToAdd; i++) {
                                    const t = i / (pointsToAdd + 1);
                                    const interpX = lastSegmentStart[0] + (lastSegmentEnd[0] - lastSegmentStart[0]) * t;
                                    const interpY = lastSegmentStart[1] + (lastSegmentEnd[1] - lastSegmentStart[1]) * t;
                                    path.splice(path.length - 1, 0, [interpX, interpY]);
                                }
                            }
                        }
                        
                        return path;
                    } catch (error) {
                        console.error('Ошибка построения точного пути:', error);
                        return [start, exactTarget];
                    }
                },

                // УЛУЧШЕННАЯ ОБРАБОТКА ДОСТИЖЕНИЯ ЦЕЛИ
                handleDestinationReached(robot) {
                    console.log(`🎯 Робот R${robot.id} достиг цели, проверяю точное позиционирование...`);
                    
                    // ЗАЩИТА ОТ ПОВТОРНОЙ ОБРАБОТКИ
                    if (robot.isAtTargetPoint && robot.targetReachedTime && 
                        Date.now() - robot.targetReachedTime < 500) {
                        console.log(`⏭️ Робот R${robot.id} уже обрабатывает эту цель, пропускаю...`);
                        return;
                    }
                    
                    // Проверяем точное позиционирование для разных типов точек
                    if (robot.status === 'moving_to_charge') {
                        // Для зарядки используем высокую точность
                        const chargingPoint = this.isAtExactPointType(
                            robot.position, 
                            'charging', 
                            POSITION_CONFIG.CHARGING_TOLERANCE
                        );
                        
                        if (chargingPoint) {
                            console.log(`🔋 Робот R${robot.id} точно на точке зарядки ${chargingPoint.pointId}`);
                            this.handleChargingDestinationReachedExact(robot, chargingPoint);
                        } else {
                            // Если не на точной точке, продолжаем движение
                            console.log(`❌ Робот R${robot.id} не на точной точке зарядки, продолжаю движение`);
                            this.sendToOptimalChargingPoint(robot);
                        }
                        return;
                    }
                    
                    // Проверяем точку погрузки
                    if (robot.currentOrder && robot.status === 'moving_to_load' && !robot.cargo) {
                        const loadingPoint = this.isAtExactPointType(
                            robot.position,
                            'loading',
                            POSITION_CONFIG.LOAD_UNLOAD_TOLERANCE
                        );
                        
                        if (loadingPoint && this.isSamePoint(loadingPoint.coordinates, robot.currentOrder.source)) {
                            console.log(`📦 Робот R${robot.id} точно на точке погрузки ${loadingPoint.pointId}`);
                            this.handleLoadingDestinationReachedExact(robot, loadingPoint);
                            return;
                        }
                    }
                    
                    // Проверяем точку выгрузки
                    if (robot.currentOrder && robot.cargo && robot.status === 'moving_to_unload') {
                        const unloadingPoint = this.isAtExactPointType(
                            robot.position,
                            'unloading',
                            POSITION_CONFIG.LOAD_UNLOAD_TOLERANCE
                        );
                        
                        if (unloadingPoint && this.isSamePoint(unloadingPoint.coordinates, robot.currentOrder.destination)) {
                            console.log(`📤 Робот R${robot.id} точно на точке выгрузки ${unloadingPoint.pointId}`);
                            this.handleUnloadingDestinationReachedExact(robot, unloadingPoint);
                            return;
                        }
                    }
                    
                    // Если ничего не найдено, используем старую логику
                    console.log(`❓ Робот R${robot.id} не нашел точную точку, использую старую логику`);
                    this.handleDestinationReachedOld(robot);
                },
                
                // СТАРАЯ ЛОГИКА (для обратной совместимости)
                handleDestinationReachedOld(robot) {
                    // Проверяем, есть ли текущий заказ
                    if (!robot.currentOrder) {
                        console.log(`⚠️ Робот R${robot.id} достиг цели, но нет заказа, перевожу в ready`);
                        robot.status = 'ready';
                        robot.targetPosition = null;
                        robot.path = [];
                        return;
                    }
                    
                    const source = robot.currentOrder.source;
                    const destination = robot.currentOrder.destination;
                    const distanceToSource = this.calculateDistance(robot.position, source);
                    const distanceToDestination = this.calculateDistance(robot.position, destination);
                    
                    console.log(`📏 Робот R${robot.id}: до погрузки=${distanceToSource.toFixed(1)}м, до выгрузки=${distanceToDestination.toFixed(1)}м`);
                    
                    // Проверка на точке погрузки
                    if (distanceToSource < 2.0 && robot.status !== 'loading' && !robot.cargo) {
                        console.log(`📦 Робot R${robot.id} достиг точки погрузки! Начинаю погрузку...`);
                        robot.status = 'loading';
                        robot.lastStatusChange = Date.now();
                        robot.isAtTargetPoint = true;
                        robot.lastTargetType = 'loading';
                        robot.targetReachedTime = Date.now();
                        
                        this.loadingRobots.set(robot.id, {
                            startTime: robot.lastStatusChange,
                            order: robot.currentOrder
                        });
                        robot.targetPosition = null;
                        robot.path = [];
                        robot.failedPathAttempts = 0;
                        return;
                    }
                    
                    // Проверка на точке выгрузки
                    if (distanceToDestination < 2.0 && robot.cargo && robot.status !== 'unloading') {
                        console.log(`📤 Робot R${robot.id} достиг точки выгрузки! Начинаю выгрузку...`);
                        robot.status = 'unloading';
                        robot.lastStatusChange = Date.now();
                        robot.isAtTargetPoint = true;
                        robot.lastTargetType = 'unloading';
                        robot.targetReachedTime = Date.now();
                        
                        this.unloadingRobots.set(robot.id, {
                            startTime: robot.lastStatusChange,
                            order: robot.currentOrder
                        });
                        robot.targetPosition = null;
                        robot.path = [];
                        robot.failedPathAttempts = 0;
                        return;
                    }
                    
                    // Если ничего не подошло
                    console.log(`❓ Робot R${robot.id} в непонятном состоянии: ${robot.status}`);
                    robot.status = 'ready';
                    robot.targetPosition = null;
                    robot.path = [];
                },

                // УЛУЧШЕННАЯ ЗАРЯДКА С ТОЧНЫМ ПОЗИЦИОНИРОВАНИЕМ
                handleChargingDestinationReachedExact(robot, chargingPoint) {
                    // Корректируем позицию к точным координатам
                    if (this.precision) {
                        const correction = this.precision.correctToExactPosition(robot, chargingPoint.coordinates);
                        if (correction.corrected) {
                            console.log(`🎯 Робot R${robot.id} скорректирован к точным координатам, смещение: ${correction.distance.toFixed(3)}м`);
                        }
                    }
                    
                    // Проверяем доступность точки
                    const connectedRobots = this.robots.filter(r => {
                        if (!r.position || r.id === robot.id) return false;
                        
                        // Роботы, которые уже заряжаются на точке
                        if (r.status === 'charging') {
                            const distToPoint = this.calculateDistance(r.position, chargingPoint.coordinates);
                            if (distToPoint < 1.5) return true;
                        }
                        
                        // Роботы, которые имеют эту точку в качестве цели
                        return r.targetChargingPointId === chargingPoint.pointId;
                    }).length;
                    
                    const pointCapacity = 1; // По умолчанию 1 место на точке
                    if (connectedRobots >= pointCapacity) {
                        console.log(`❌ Точка зарядки ${chargingPoint.pointId} занята, ищу другую`);
                        this.sendToOptimalChargingPoint(robot);
                        return;
                    }
                    
                    // Начинаем зарядку
                    robot.status = 'charging';
                    robot.lastStatusChange = Date.now();
                    robot.isAtTargetPoint = true;
                    robot.lastTargetType = 'charging';
                    robot.targetReachedTime = Date.now();
                    robot.targetPosition = null;
                    robot.path = [];
                    robot.currentOrder = null;
                    robot.currentDelivery = null;
                    robot.cargo = null;
                    
                    // Запоминаем точку зарядки
                    robot.lastChargingPoint = [...chargingPoint.coordinates];
                    robot.targetChargingPointId = chargingPoint.pointId;
                    
                    this.chargingRobots.set(robot.id, robot.lastStatusChange);
                    
                    console.log(`⚡ Робot R${robot.id} начинает зарядку на точке ${chargingPoint.pointId}`);
                },

                // УЛУЧШЕННАЯ ПОГРУЗКА С ТОЧНЫМ ПОЗИЦИОНИРОВАНИЕМ
                handleLoadingDestinationReachedExact(robot, loadingPoint) {
                    // Корректируем позицию
                    if (this.precision) {
                        this.precision.correctToExactPosition(robot, loadingPoint.coordinates);
                    }
                    
                    // Начинаем погрузку
                    robot.status = 'loading';
                    robot.lastStatusChange = Date.now();
                    robot.isAtTargetPoint = true;
                    robot.lastTargetType = 'loading';
                    robot.targetReachedTime = Date.now();
                    robot.targetPosition = null;
                    robot.path = [];
                    
                    this.loadingRobots.set(robot.id, {
                        startTime: robot.lastStatusChange,
                        order: robot.currentOrder,
                        pointId: loadingPoint.pointId
                    });
                    
                    console.log(`📦 Робot R${robot.id} начинает погрузку на точке ${loadingPoint.pointId}`);
                },
                
                // УЛУЧШЕННАЯ ВЫГРУЗКА С ТОЧНЫМ ПОЗИЦИОНИРОВАНИЕМ
                handleUnloadingDestinationReachedExact(robot, unloadingPoint) {
                    // Корректируем позицию
                    if (this.precision) {
                        this.precision.correctToExactPosition(robot, unloadingPoint.coordinates);
                    }
                    
                    // Начинаем выгрузку
                    robot.status = 'unloading';
                    robot.lastStatusChange = Date.now();
                    robot.isAtTargetPoint = true;
                    robot.lastTargetType = 'unloading';
                    robot.targetReachedTime = Date.now();
                    robot.targetPosition = null;
                    robot.path = [];
                    
                    this.unloadingRobots.set(robot.id, {
                        startTime: robot.lastStatusChange,
                        order: robot.currentOrder,
                        pointId: unloadingPoint.pointId
                    });
                    
                    console.log(`📤 Робot R${robot.id} начинает выгрузку на точке ${unloadingPoint.pointId}`);
                },

                // УЛУЧШЕННОЕ ДВИЖЕНИЕ С ТОЧНЫМ ФИНИШЕМ
                followPathWithExactFinish(robot) {
                    if (!robot.path || robot.path.length === 0) {
                        this.handleDestinationReached(robot);
                        return;
                    }
                    
                    // Определяем, какая точка является финишной
                    const isLastPoint = robot.currentPathIndex >= robot.path.length - 1;
                    const targetPoint = robot.path[robot.currentPathIndex];
                    
                    // Определяем допуск в зависимости от типа точки
                    let tolerance = POSITION_CONFIG.PATH_POINT_TOLERANCE;
                    if (isLastPoint) {
                        // Для последней точки используем более высокую точность
                        if (robot.status === 'moving_to_charge') {
                            tolerance = POSITION_CONFIG.CHARGING_TOLERANCE;
                        } else if (robot.status === 'moving_to_load' || robot.status === 'moving_to_unload') {
                            tolerance = POSITION_CONFIG.LOAD_UNLOAD_TOLERANCE;
                        }
                    }
                    
                    const dx = targetPoint[0] - robot.position[0];
                    const dy = targetPoint[1] - robot.position[1];
                    const distance = Math.sqrt(dx * dx + dy * dy);
                    
                    if (distance < tolerance) {
                        if (isLastPoint) {
                            // Достигли конечной точки - точное позиционирование
                            console.log(`🎯 Робot R${robot.id} достиг конечной точки, точное позиционирование`);
                            
                            // Устанавливаем точные координаты
                            robot.position[0] = targetPoint[0];
                            robot.position[1] = targetPoint[1];
                            
                            // Обрабатываем достижение цели
                            this.handleDestinationReached(robot);
                        } else {
                            // Переходим к следующей точке пути
                            robot.currentPathIndex++;
                            if (robot.currentPathIndex < robot.path.length) {
                                robot.targetPosition = robot.path[robot.currentPathIndex];
                                console.log(`➡️ Робot R${robot.id} переходит к точке ${robot.currentPathIndex + 1}/${robot.path.length}`);
                            }
                        }
                    } else {
                        // Движение к точке с адаптивной скоростью
                        this.moveToPointWithAdaptiveSpeed(robot, targetPoint, isLastPoint);
                    }
                },
                
                // ДВИЖЕНИЕ С АДАПТИВНОЙ СКОРОСТЬЮ
                moveToPointWithAdaptiveSpeed(robot, targetPoint, isLastPoint = false) {
                    const dx = targetPoint[0] - robot.position[0];
                    const dy = targetPoint[1] - robot.position[1];
                    const distance = Math.sqrt(dx * dx + dy * dy);
                    
                    // Определяем коэффициент скорости
                    let speedFactor;
                    if (distance > POSITION_CONFIG.SLOWDOWN_DISTANCE) {
                        speedFactor = POSITION_CONFIG.NORMAL_SPEED;
                    } else if (distance > 0.5) {
                        speedFactor = POSITION_CONFIG.SLOW_SPEED;
                    } else if (isLastPoint) {
                        speedFactor = POSITION_CONFIG.PRECISION_SPEED; // Медленно для точности
                    } else {
                        speedFactor = POSITION_CONFIG.SLOW_SPEED;
                    }
                    
                    const speed = (robot.speed || 4.5) * speedFactor * 0.02;
                    const ratio = Math.min(1, speed / distance);
                    
                    const moveX = dx * ratio;
                    const moveY = dy * ratio;
                    
                    const newPosition = [robot.position[0] + moveX, robot.position[1] + moveY];
                    
                    if (!this.checkCollision(newPosition, 0.5)) {
                        robot.position[0] = newPosition[0];
                        robot.position[1] = newPosition[1];
                        
                        // Расход батареи
                        const batteryConsumption = (robot.batteryConsumption || 0.02) * ratio;
                        robot.battery = Math.max(0, (robot.battery || 100) - batteryConsumption);
                        robot.totalDistance = (robot.totalDistance || 0) + Math.sqrt(moveX * moveX + moveY * moveY);
                        
                        // Сохраняем историю движения для отладки
                        if (!robot.movementHistory) robot.movementHistory = [];
                        robot.movementHistory.push({
                            time: Date.now(),
                            position: [...robot.position],
                            target: [...targetPoint],
                            distance: distance
                        });
                        
                        // Ограничиваем размер истории
                        if (robot.movementHistory.length > 50) {
                            robot.movementHistory = robot.movementHistory.slice(-50);
                        }
                    } else {
                        robot.failedPathAttempts = (robot.failedPathAttempts || 0) + 1;
                        if (robot.failedPathAttempts > 3) {
                            this.replanPath(robot);
                        }
                    }
                },

                // ДОБАВИТЬ метод для проверки, находится ли робот на целевой точке
                checkIfAtTarget(robot) {
                    if (!robot.targetPosition) return false;
                    
                    const distance = this.calculateDistance(robot.position, robot.targetPosition);
                    return distance < 0.5;
                },

                // Улучшенная обработка достижения точки зарядки с защитой от дергания
                handleChargingDestinationReached(robot) {
                    const chargingPoint = this.findChargingPointByCoordinates(robot.position);
                    
                    if (chargingPoint) {
                        // Проверяем, не переполнена ли точка зарядки
                        const connectedRobots = this.robots.filter(r => {
                            if (!r.position || r.id === robot.id) return false;
                            
                            // Роботы, которые уже заряжаются на точке
                            if (r.status === 'charging') {
                                const distToPoint = this.calculateDistance(r.position, chargingPoint.coordinates);
                                if (distToPoint < 1.5) return true;
                            }
                            
                            // Роботы, которые имеют эту точку в качестве цели
                            const pointId = chargingPoint.id || `charge_${chargingPoint.coordinates[0]}_${chargingPoint.coordinates[1]}`;
                            return r.targetChargingPointId === pointId;
                        }).length;
                        
                        const capacity = chargingPoint.chargingPlaces || 1;
                        
                        if (connectedRobots >= capacity) {
                            // Точка переполнена, ищем другую
                            console.log(`❌ Точка зарядки переполнена, робот R${robot.id} ищет другую`);
                            this.sendToOptimalChargingPoint(robot);
                            return;
                        }
                    }
                    
                    // ЗАЩИТА ОТ ПОВТОРНОГО НАЧАЛА ЗАРЯДКИ
                    if (robot.status === 'charging' || robot.isAtTargetPoint) {
                        console.log(`⏭️ Робот R${robot.id} уже заряжается, пропускаю...`);
                        return;
                    }
                    
                    // Начинаем зарядку
                    console.log(`🔋 Робот R${robot.id} начинает зарядку на точке [${robot.position[0]}, ${robot.position[1]}]`);
                    robot.status = 'charging';
                    robot.lastStatusChange = Date.now();
                    robot.isAtTargetPoint = true;
                    robot.lastTargetType = 'charging';
                    robot.targetReachedTime = Date.now();
                    
                    this.chargingRobots.set(robot.id, robot.lastStatusChange);
                    robot.targetPosition = null;
                    robot.path = [];
                    
                    // Сбрасываем все задания при начале зарядки
                    robot.currentOrder = null;
                    robot.currentDelivery = null;
                    robot.cargo = null;
                },

                findChargingPointByCoordinates(position) {
                    const chargingPoints = this.data.chargingPoints || [];
                    for (const point of chargingPoints) {
                        const distance = this.calculateDistance(position, point.coordinates);
                        if (distance < 2.0) {
                            return point;
                        }
                    }
                    return null;
                },

                // ИСПРАВЛЕННОЕ обновление зарядки с защитой от дергания
                updateCharging() {
                    const now = Date.now();
                    
                    this.chargingRobots.forEach((startTime, robotId) => {
                        const robot = this.robots.find(r => r.id === robotId);
                        if (robot && robot.status === 'charging') {
                            // ЗАРЯЖАЕМСЯ ДО 100%
                            robot.battery = Math.min(100, robot.battery + (robot.chargingSpeed || 1.0));
                            
                            // Минимальное время зарядки - 5 секунд
                            const minChargingTime = 5000;
                            const chargingTime = now - startTime;
                            
                            // ТОЛЬКО при 100% заряде И минимальном времени
                            if (robot.battery >= 100 && chargingTime >= minChargingTime) {
                                console.log(`✅ Робот R${robot.id} полностью заряжен до 100%`);
                                
                                // ОСВОБОЖДАЕМ точку зарядки
                                console.log(`🔓 Робот R${robot.id} освобождает точку зарядки ${robot.targetChargingPointId}`);
                                robot.targetChargingPointId = null;
                                
                                // Запоминаем точку зарядки
                                const chargingPoint = this.findChargingPointByCoordinates(robot.position);
                                if (chargingPoint) {
                                    robot.lastChargingPoint = [...chargingPoint.coordinates];
                                }
                                
                                // Запоминаем время окончания зарядки
                                robot.lastChargingEndTime = Date.now();
                                
                                robot.status = 'ready';
                                this.chargingRobots.delete(robotId);
                                
                                // СБРАСЫВАЕМ флаги
                                robot.isAtTargetPoint = false;
                                robot.lastTargetType = null;
                                robot.targetReachedTime = null;
                                
                                // Ждем 3 секунды перед любыми действиями
                                setTimeout(() => {
                                    if (robot.status === 'ready' && !robot.currentOrder) {
                                        this.findAndAssignNextTask(robot);
                                    }
                                }, 3000);
                            } else if (robot.battery >= this.BATTERY_CONFIG.MIN_READY_THRESHOLD && chargingTime >= minChargingTime) {
                                // Если достигли порога готовности, но не 100%
                                console.log(`✅ Робот R${robot.id} заряжен до ${robot.battery}% (порог: ${this.BATTERY_CONFIG.MIN_READY_THRESHOLD}%)`);
                                
                                // ОСВОБОЖДАЕМ точку зарядки
                                console.log(`🔓 Робот R${robot.id} освобождает точку зарядки ${robot.targetChargingPointId}`);
                                robot.targetChargingPointId = null;
                                
                                robot.lastChargingEndTime = Date.now();
                                robot.status = 'ready';
                                this.chargingRobots.delete(robotId);
                                
                                // СБРАСЫВАЕМ флаги
                                robot.isAtTargetPoint = false;
                                robot.lastTargetType = null;
                                robot.targetReachedTime = null;
                                
                                // Ждем 2 секунды
                                setTimeout(() => {
                                    if (robot.status === 'ready' && !robot.currentOrder) {
                                        this.findAndAssignNextTask(robot);
                                    }
                                }, 2000);
                            }
                        }
                    });
                },

                // ИСПРАВЛЕННОЕ обновление погрузки/выгрузки
                updateLoadingUnloading() {
                    const now = Date.now();
                    
                    this.loadingRobots.forEach((data, robotId) => {
                        if (now - data.startTime > 1500) { // УВЕЛИЧЕНО время погрузки с 800 до 1500
                            const robot = this.robots.find(r => r.id === robotId);
                            if (robot && robot.currentOrder) {
                                console.log(`✅ Робот R${robot.id} завершил погрузку ${robot.currentOrder.cargoType}`);
                                
                                robot.cargo = {
                                    type: robot.currentOrder.cargoType,
                                    units: robot.currentOrder.units,
                                    weight: robot.currentOrder.weight
                                };
                                robot.status = 'moving_to_unload';
                                
                                // СБРАСЫВАЕМ флаги перед началом движения
                                robot.isAtTargetPoint = false;
                                robot.lastTargetType = null;
                                robot.targetReachedTime = null;
                                
                                const pathToUnloading = this.findPath(robot.position, robot.currentOrder.destination);
                                if (pathToUnloading && pathToUnloading.length > 1) {
                                    robot.path = pathToUnloading;
                                    robot.currentPathIndex = 1;
                                    robot.targetPosition = robot.path[robot.currentPathIndex];
                                    console.log(`🗺️ Робот R${robot.id} построил путь к выгрузке из ${pathToUnloading.length} точек`);
                                } else {
                                    robot.targetPosition = robot.currentOrder.destination;
                                    console.log(`➡️ Робот R${robot.id} движется напрямую к выгрузке`);
                                }
                                
                                this.loadingRobots.delete(robotId);
                            }
                        }
                    });
                    
                    this.unloadingRobots.forEach((data, robotId) => {
                        if (now - data.startTime > 1500) { // УВЕЛИЧЕНО время выгрузки с 800 до 1500
                            const robot = this.robots.find(r => r.id === robotId);
                            if (robot && robot.currentOrder && robot.cargo) {
                                console.log(`✅ Робот R${robot.id} завершает выгрузку ${robot.cargo.type}`);
                                this.processUnloading(robot, data.order);
                                
                                // СБРАСЫВАЕМ флаги
                                robot.isAtTargetPoint = false;
                                robot.lastTargetType = null;
                                robot.targetReachedTime = null;
                                
                                this.unloadingRobots.delete(robotId);
                            }
                        }
                    });
                },

                // ИСПРАВЛЕННАЯ ОБРАБОТКА ВЫГРУЗКИ
                processUnloading(robot, order) {
                    if (!order || !order.progressKey) {
                        console.warn(`❌ Некорректный заказ для выгрузки роботом R${robot.id}`);
                        robot.cargo = null;
                        robot.currentOrder = null;
                        
                        // ВАЖНО: Принудительно завершаем статус выгрузки
                        robot.status = 'ready';
                        robot.isAtTargetPoint = false;
                        robot.lastTargetType = null;
                        robot.targetReachedTime = null;
                        
                        this.unloadingRobots.delete(robot.id);
                        
                        this.checkBatteryAfterUnloading(robot);
                        return;
                    }
                    
                    const progress = this.deliveryProgress.get(order.progressKey);
                    
                    if (progress) {
                        progress.delivered = (progress.delivered || 0) + (order.weight || 0);
                        robot.deliveriesCompleted = (robot.deliveriesCompleted || 0) + 1;
                        
                        if (progress.delivered >= (progress.totalRequired || 0)) {
                            progress.completed = true;
                            progress.delivered = progress.totalRequired;
                            this.completedDeliveries++;
                            robot.currentDelivery = null;
                        } else if (robot.currentDelivery) {
                            robot.currentDelivery.totalDelivered = (robot.currentDelivery.totalDelivered || 0) + (order.weight || 0);
                        }
                    }
                    
                    console.log(`✅ Робот R${robot.id} успешно выгрузил ${order.weight}кг ${order.cargoType}`);
                    
                    // Сбрасываем груз и задание
                    robot.cargo = null;
                    robot.currentOrder = null;
                    
                    // ВАЖНО: Принудительно завершаем статус выгрузки
                    robot.status = 'ready';
                    robot.isAtTargetPoint = false;
                    robot.lastTargetType = null;
                    robot.targetReachedTime = null;
                    
                    // Удаляем из unloadingRobots
                    this.unloadingRobots.delete(robot.id);
                    
                    // ПОСЛЕ ВЫГРУЗКИ ПРОВЕРЯЕМ ЗАРЯД
                    this.checkBatteryAfterUnloading(robot);
                },

                // ИСПРАВЛЕННАЯ ПРОВЕРКА БАТАРЕИ ПОСЛЕ ВЫГРУЗКИ
                checkBatteryAfterUnloading(robot) {
                    // СНАЧАЛА убедимся, что робот не в статусе unloading
                    if (robot.status === 'unloading') {
                        console.warn(`⚠️ Робот R${robot.id} все еще в статусе unloading, принудительно завершаю`);
                        robot.status = 'ready';
                        this.unloadingRobots.delete(robot.id);
                    }
                    
                    // После выгрузки проверяем заряд батареи
                    if (robot.battery < this.BATTERY_CONFIG.EMERGENCY_THRESHOLD) {
                        console.log(`🔋 Робот R${robot.id} после выгрузки имеет низкий заряд (${robot.battery}%), еду на зарядку`);
                        this.sendToOptimalChargingPoint(robot);
                    } else if (this.areAllDeliveriesCompleted() && robot.battery < this.BATTERY_CONFIG.MIN_READY_THRESHOLD) {
                        // ВСЕ задания выполнены И заряд ниже порога готовности
                        console.log(`🔋 Робот R${robot.id}: все задания выполнены, заряд ${robot.battery}% < ${this.BATTERY_CONFIG.MIN_READY_THRESHOLD}%, еду на зарядку`);
                        this.sendToOptimalChargingPoint(robot);
                    } else {
                        // Если заряд нормальный - ищем следующее задание
                        this.findAndAssignNextTask(robot);
                    }
                },

                // ИСПРАВЛЕННОЕ назначение начальных заданий  
                assignInitialOrders() {
