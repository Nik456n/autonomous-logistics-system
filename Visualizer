                // ИСПРАВЛЕННАЯ функция для принудительного назначения заданий
                forceAssignOrders() {
                    console.log('🔧 Принудительно назначаю задания всем готовым роботам...');
                    
                    let assignedCount = 0;
                    this.robots.forEach(robot => {
